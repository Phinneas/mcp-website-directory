# PulseMCP API Configuration
PULSEMCP_API_URL=http://localhost:3001

# Set to 'true' to force using static data instead of API
USE_STATIC_DATA=false

# MeiliSearch Configuration (configure these in Railway/production)
MEILISEARCH_HOST=your_meilisearch_host
MEILISEARCH_API_KEY=your_meilisearch_api_key
MEILISEARCH_ADMIN_KEY=your_admin_key_for_indexing

# Railway Environment Variables
PORT=3000
NODE_ENV=production

# Beehiiv Newsletter Integration
# Get your credentials from: https://app.beehiiv.com/settings/integrations
BEEHIIV_API_KEY=bh_your_api_key_here
BEEHIIV_PUBLICATION_ID=pub_your_publication_id_here

# Tavily Configuration (for server discovery)
TAVILY_API_KEY=your_tavily_api_key_here

# Newsletter Configuration
NEWSLETTER_WEEKLY_DAY=1
NEWSLETTER_WEEKLY_HOUR=9
NEWSLETTER_MONTHLY_DAY=1
NEWSLETTER_MONTHLY_HOUR=9
NEWSLETTER_TIMEZONE=UTC

# Cross-promotion
AI_DISPATCH_URL=https://aidispatch.com

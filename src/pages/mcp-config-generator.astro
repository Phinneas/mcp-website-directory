---
export const prerender = true;
/**
 * MCP Config Generator Page
 * One-Click Config Generator for MCP clients
 */
import { staticServers as importedStaticServers } from '../data/staticServers.js';
import MCPConfigGenerator from '../components/MCPConfigGenerator';
import BaseLayout from '../layouts/BaseLayout.astro';

// Import static servers
const staticServers = importedStaticServers;
---

<BaseLayout
  title="MCP Config Generator | MyMCPShelf"
  description="Generate MCP server configuration for Claude Desktop, Cursor, Cline, and other clients with one click"
  canonical="https://www.mymcpshelf.com/mcp-config-generator"
>
  <div class="page-container">
    <!-- Hero -->
    <div class="hero">
      <h1>MCP Config Generator</h1>
      <p>
        Select your MCP client and servers, then generate ready-to-use configuration
        in seconds. No manual JSON editing required.
      </p>
    </div>

    <!-- Supported Clients -->
    <div class="supported-clients">
      <span class="client-badge">Claude Desktop</span>
      <span class="client-badge">Cursor</span>
      <span class="client-badge">Cline</span>
      <span class="client-badge">Continue</span>
      <span class="client-badge">VS Code</span>
    </div>

    <!-- Features -->
    <div class="feature-grid">
      <div class="feature-card">
        <h3>🎯 One-Click Setup</h3>
        <p>Select servers and generate complete configuration instantly. No manual JSON editing required.</p>
      </div>
      <div class="feature-card">
        <h3>🤖 Client-Specific Formats</h3>
        <p>Automatically generates correct config format for your MCP client (Claude Desktop, Cursor, Cline, etc.)</p>
      </div>
      <div class="feature-card">
        <h3>📋 Ready to Copy</h3>
        <p>One-click copy to clipboard with clear instructions for where to save your config file.</p>
      </div>
    </div>

    <!-- Config Generator Component -->
    <MCPConfigGenerator
      client:load
      servers={staticServers}
    />

    <!-- Footer -->
    <footer style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); color: #64748b; text-align: center; font-size: 0.875rem;">
      <p>Build your MCP server configuration in seconds. No more manual JSON editing.</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    padding: 3rem 0;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #f59e0b 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.125rem;
    color: #94a3b8;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .supported-clients {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin: 2rem 0;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .client-badge {
    padding: 0.5rem 1rem;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #f59e0b;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .feature-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: #f1f5f9;
  }

  .feature-card p {
    color: #94a3b8;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .nav-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #94a3b8;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-links a:hover {
    color: #f59e0b;
    border-color: #f59e0b;
  }

  @media (max-width: 768px) {
    .page-container { padding: 1rem; }
    .hero h1 { font-size: 2rem; }
    .nav-header { flex-direction: column; align-items: flex-start; }
    .nav-links { width: 100%; }
    .nav-links a { flex: 1; justify-content: center; }
  }
</style>

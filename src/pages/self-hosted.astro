---
import { getServersPage } from '../utils/d1';
import type { MCPServer } from '../utils/d1';
import ServerGrid from '../components/ServerGrid';
import { filterServersByDeployment } from '../utils/serverData.js';
import { staticServers } from '../data/staticServers.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/deployment-page.css';

const DEPLOYMENT_CONFIG = {
  deploymentType: 'self_hosted',
  title: 'Self-Hosted MCP Servers',
  subtitle: 'on-premise/VPC deployment options',
  description: 'Find MCP servers perfect for self-hosted deployment in your own infrastructure. Ideal for VPC, on-premise data centers, and private cloud environments requiring full data control and compliance.',
  heroTitle: 'Self-Hosted MCP Servers',
  heroDescription: 'Deploy MCP servers in your own infrastructure with complete control over data, security, and compliance. Perfect for VPCs, private clouds, and regulated environments.',
  tagline: 'Deploy in your infrastructure, own your data',
  features: [
    'Complete data sovereignty and control',
    'Deploy in VPC or on-premise infrastructure',
    'Full compliance and audit capabilities',
    'Custom security policies and controls',
    'Integration with existing infrastructure',
    'No vendor lock-in or external dependencies',
  ],
  requirements: [
    'Server infrastructure (VMs, containers, Kubernetes)',
    'Network configuration and firewall management',
    'Docker or container runtime',
    'System administration skills',
    'Backup and monitoring setup',
  ],
  useCases: [
    'Enterprise compliance requirements',
    'Data sovereignty and residency',
    'Regulated industries (healthcare, finance)',
    'Private cloud infrastructure',
    'Air-gapped or secure environments',
    'Custom integration needs',
  ],
};

const db = (Astro.locals as any).runtime?.env?.DB as D1Database | undefined;
let initialServers: MCPServer[] = [];
let total = 0;

if (db) {
  try {
    const result = await getServersPage(db, { limit: 48, deployment: DEPLOYMENT_CONFIG.deploymentType });
    initialServers = result.servers;
    total = result.total;
  } catch (error) {
    console.error(`Error fetching servers for ${DEPLOYMENT_CONFIG.deploymentType}:`, error);
  }
} else {
  const filteredServers = filterServersByDeployment(staticServers as any[] as MCPServer[], DEPLOYMENT_CONFIG.deploymentType);
  initialServers = filteredServers.slice(0, 48);
  total = filteredServers.length;
}

const canonicalUrl = 'https://www.mymcpshelf.com/self-hosted';
const pageTitle = `${DEPLOYMENT_CONFIG.title} | My MCP Shelf`;
const pageDescription = `${DEPLOYMENT_CONFIG.description} Browse ${total}+ self-hosted MCP servers.`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: DEPLOYMENT_CONFIG.title,
  description: pageDescription,
  url: canonicalUrl,
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  structuredData={structuredData}
>
  <div transition:name="main-content">
    <section class="hero-section">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="page-title">{DEPLOYMENT_CONFIG.heroTitle}</h1>
          <p class="page-subtitle">{DEPLOYMENT_CONFIG.heroDescription}</p>
          <div class="tagline-badge">
            <span>🏢</span>
            {DEPLOYMENT_CONFIG.tagline}
          </div>
        </div>
        <div class="hero-badges">
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-value">{total}</span>
              <span class="stat-label">Servers</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">VPC</span>
              <span class="stat-label">Ready</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">100%</span>
              <span class="stat-label">Control</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main class="page-container">
      <section class="deployment-info">
        <h2>About {DEPLOYMENT_CONFIG.title}</h2>
        <p>{DEPLOYMENT_CONFIG.description}</p>
        <div class="info-grid">
          <div class="info-section">
            <h3>✨ Key Features</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.features.map(f => <li>{f}</li>)}
            </ul>
          </div>
          <div class="info-section">
            <h3>⚙️ Requirements</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.requirements.map(r => <li>{r}</li>)}
            </ul>
          </div>
          <div class="info-section">
            <h3>💡 Use Cases</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.useCases.map(u => <li>{u}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="grid-section">
        <div class="section-header">
          <div>
            <h2 class="section-title">{initialServers.length > 0 ? `${total}+ ${DEPLOYMENT_CONFIG.title}` : 'Browse Servers'}</h2>
            <p class="section-description">Discover the best MCP servers optimized for {DEPLOYMENT_CONFIG.subtitle}</p>
          </div>
        </div>
        {initialServers.length > 0 ? (
          <ServerGrid client:load initialServers={initialServers} total={total} meta={{ deployment: DEPLOYMENT_CONFIG.deploymentType }} />
        ) : (
          <div class="no-results">
            <h3>No servers found for this deployment type yet</h3>
            <p>Check back soon or <a href="/submit-server">submit a new server</a>.</p>
          </div>
        )}
      </section>

      <section class="comparison-section">
        <h2>Not sure which deployment is right for you?</h2>
        <p>Compare deployment options and find the best fit for your infrastructure needs.</p>
        <div class="comparison-cta">
          <a href="/enterprise-readiness" class="btn">Compare Deployment Options →</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

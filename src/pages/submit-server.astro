---
export const prerender = true;
/**
 * Submit MCP Server Page
 * Allows visitors to submit their MCP servers to the directory
 */
import MCPServerSubmitForm from '../components/MCPServerSubmitForm';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Submit Your MCP Server | MyMCPShelf"
  description="Submit your MCP server to the directory and share it with the community"
  canonical="https://www.mymcpshelf.com/submit-server"
>
  <div class="page-container">
    <!-- Hero -->
    <div class="hero">
      <h1>Submit Your MCP Server</h1>
      <p>
        Share your MCP server with the community. After review, your server will be
        added to the directory for thousands of users to discover.
      </p>
    </div>

    <!-- Benefits -->
    <div class="benefits">
      <div class="benefit-card">
        <div class="benefit-icon">🚀</div>
        <h4>Reach Users</h4>
        <p>Get discovered by developers and AI enthusiasts</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">⭐</div>
        <h4>Build Community</h4>
        <p>Grow your user base and get feedback</p>
      </div>
      <div class="benefit-card">
        <div class="benefit-icon">📊</div>
        <h4>Track Metrics</h4>
        <p>See how many users configure your server</p>
      </div>
    </div>

    <!-- Requirements -->
    <div class="requirements">
      <h3>Before You Submit</h3>
      <ul>
        <li>Your server implements the MCP protocol</li>
        <li>Code is publicly available on GitHub</li>
        <li>Documentation includes setup instructions</li>
        <li>Server is actively maintained</li>
      </ul>
    </div>

    <!-- Submission Form -->
    <MCPServerSubmitForm client:load />

    <!-- Footer -->
    <footer class="page-footer">
      <p>Submissions are typically reviewed within 24-48 hours.</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    padding: 2rem 0;
  }

  .hero h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #f59e0b 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.1rem;
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .benefits {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  .benefit-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
  }

  .benefit-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .benefit-card h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #f1f5f9;
  }

  .benefit-card p {
    font-size: 0.875rem;
    color: #94a3b8;
    margin: 0;
  }

  .requirements {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .requirements h3 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
    color: #f1f5f9;
  }

  .requirements ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .requirements li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: #94a3b8;
    font-size: 0.95rem;
  }

  .requirements li::before {
    content: '✓';
    color: #10b981;
    font-weight: bold;
  }

  .page-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    color: #64748b;
    font-size: 0.875rem;
  }

  /* Navigation helper */
  .nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .nav-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #94a3b8;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-links a:hover {
    color: #f59e0b;
    border-color: #f59e0b;
  }

  @media (max-width: 768px) {
    .page-container { padding: 1rem; }
    .hero h1 { font-size: 1.75rem; }
    .nav-header { flex-direction: column; align-items: flex-start; }
    .nav-links { width: 100%; }
    .nav-links a { flex: 1; justify-content: center; }
  }
</style>

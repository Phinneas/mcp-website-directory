---
/**
 * SSR MCP Server Detail Page
 * URL: /server/[slug]
 *
 * Switched from prerender=true to SSR to fix Cloudflare 404s caused by:
 *  1. Slug mismatch between ServerGrid's inline slugify and the build-time slugify
 *  2. No deduplication in ServerGrid links
 *  3. D1 servers missing from the build-time servers.json snapshot
 *
 * Now: slug map is built at request time from the same canonical slugify,
 * so every card link is guaranteed to resolve.
 */
import ServerHeader from '../../components/ServerHeader.astro';
import ServerInstallation from '../../components/ServerInstallation.astro';
import ServerConfiguration from '../../components/ServerConfiguration.astro';
import ServerTools from '../../components/ServerTools.astro';
import ServerMetadata from '../../components/ServerMetadata.astro';
import RelatedServers from '../../components/RelatedServers.astro';
import GitHubHealthVitals from '../../components/GitHubHealthVitals';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRelatedServers, getCategoryDisplayName } from '../../utils/serverData.js';
import { slugify } from '../../utils/slugify.js';
import { staticServers as fallbackServers } from '../../data/staticServers.js';
import { getSecurityAudit, getScoreTier } from '../../data/securityAudit';
import CustomMcpCta from '../../components/CustomMcpCta.astro';
import { GreenBadge } from '../../components/GreenBadge';

// servers.json is bundled by Vite at build time — safe to import statically
import serversData from '../../data/servers.json';

interface MCPServer {
  id: string;
  slug?: string;
  deployment?: string;
  deployment_metadata?: { capabilities?: string[]; secondary_deployments?: string[] };
  enterprise_features?: string[];
  fields: {
    name: string;
    description: string;
    version?: string;
    status?: string;
    author?: string;
    category?: string;
    language?: string;
    stars?: number;
    github_url?: string;
    npm_package?: string;
    downloads?: number;
    updated?: string;
    license?: string;
    homepage_url?: string;
    documentation_url?: string;
    tags?: string[];
    prerequisites?: string[];
    logoUrl?: string;
    logoSource?: string;
    logoCachedAt?: string;
    available_tools?: Array<{ name: string; description: string; category?: string }>;
    environment_variables?: Array<{ name: string; description: string; required: boolean; default?: string }>;
  };
}

// Pick the richest data source available
const allServers: MCPServer[] = (
  Array.isArray(serversData?.servers) && serversData.servers.length > 0
    ? serversData.servers
    : fallbackServers
) as MCPServer[];

// Build deduplicated slug → server map using the canonical slugify
// (matches the same logic ServerGrid uses via slugify.js)
const usedSlugs = new Set<string>();
const slugMap = new Map<string, MCPServer>();

for (const srv of allServers) {
  const name = srv.fields?.name || srv.id;
  let s = slugify(name);
  if (!s) continue;

  if (usedSlugs.has(s)) {
    let counter = 2;
    while (usedSlugs.has(`${s}-${counter}`)) counter++;
    s = `${s}-${counter}`;
  }
  usedSlugs.add(s);
  slugMap.set(s, srv);
}

const { slug } = Astro.params;
const server = slug ? slugMap.get(slug) : undefined;

// Hard 404 if slug doesn't match any known server
if (!server) {
  return new Response('Server not found', { status: 404 });
}

// Related servers
const relatedServers = getRelatedServers(server, allServers, 5);

// Security audit data (from manual audit data file + D1 data)
const auditData = getSecurityAudit(server.id) || (server as any).securityAudit || null;
const auditTier = auditData ? getScoreTier(auditData.auditScore) : null;
const greenScore = (server as any).greenScore || null;

const TRANSPORT_LABELS: Record<string, string> = { stdio: 'Stdio (Local)', sse_http: 'SSE/HTTP (Remote)', both: 'Both' };
const AUTH_LABELS: Record<string, string> = { None: 'None', 'API Key': 'API Key', OAuth2: 'OAuth2', 'SSO-SAML': 'SSO/SAML' };
const TOKEN_LABELS: Record<string, string> = { 'short-lived': 'Short-lived (Refresh)', 'long-lived': 'Long-lived (Static)', 'N/A': 'N/A' };
const INPUT_LABELS: Record<string, string> = { parameterized: 'Parameterized (Safe)', shell_strings: 'Shell Strings (Risky)', mixed: 'Mixed' };
const RESIDENCY_LABELS: Record<string, string> = { local_only: 'Local Only', cloud: 'Cloud', hybrid: 'Hybrid', unknown: 'Unknown' };

// SEO
const serverName = server.fields.name;
const serverDescription = server.fields.description || `Learn about ${serverName} MCP server`;
const truncatedDescription = serverDescription.length > 160
  ? serverDescription.substring(0, 157) + '...'
  : serverDescription;
const canonicalUrl = `https://www.mymcpshelf.com/server/${slug}`;
const categoryDisplay = getCategoryDisplayName(server.fields.category);

const deploymentCategoryMap: Record<string, string> = {
  local_stdio: 'DesktopApplication',
  cloud_native: 'WebApplication',
  self_hosted: 'WebApplication',
  enterprise_saas: 'BusinessApplication',
  hybrid: 'DeveloperApplication',
};

const deploymentCategoryNameMap: Record<string, string> = {
  local_stdio: 'Local Deployment',
  cloud_native: 'Cloud-Native Application',
  self_hosted: 'Self-Hosted Software',
  enterprise_saas: 'Enterprise SaaS Software',
  hybrid: 'Multi-Deployment Software',
};

function getDeploymentRequirements(dt: string): string {
  const r: Record<string, string> = {
    local_stdio: 'Local CLI access and runtime environment (Node.js/Python)',
    cloud_native: 'Internet access and cloud provider credentials',
    self_hosted: 'Server infrastructure with Docker/Kubernetes support',
    enterprise_saas: 'Enterprise subscription and SSO integration',
    hybrid: 'Depends on selected deployment mode',
  };
  return r[dt] || 'Cross-platform compatible';
}

function calculateRatingFromStars(stars: number): string {
  const rating = Math.max(1, Math.min(5, 1 + (stars / 100) * 4));
  return rating.toFixed(1);
}

const currentDeployment = server.deployment || 'hybrid';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: serverName,
  alternateName: `${serverName} MCP Server`,
  description: serverDescription,
  url: canonicalUrl,
  applicationCategory: deploymentCategoryMap[currentDeployment] || 'DeveloperApplication',
  applicationSubCategory: deploymentCategoryNameMap[currentDeployment] || 'Development Tools',
  operatingSystem: ['Any', 'Cross-platform'],
  requirements: getDeploymentRequirements(currentDeployment),
  ...(server.fields.author && {
    author: { '@type': 'Person', name: server.fields.author.replace('@', '') },
  }),
  ...(server.fields.github_url && { codeRepository: server.fields.github_url }),
  programmingLanguage: server.fields.language || 'Unknown',
  ...(server.fields.license && { license: server.fields.license }),
  softwareVersion: server.fields.version || '1.0.0',
  featureList: server.deployment_metadata?.capabilities || ['MCP Protocol'],
  softwareCategory: categoryDisplay,
  datePublished: server.fields.updated || new Date().toISOString(),
  dateModified: server.fields.updated || new Date().toISOString(),
  ...(server.fields.stars && {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: calculateRatingFromStars(server.fields.stars),
      reviewCount: Math.max(1, Math.floor(server.fields.stars / 10)),
      bestRating: '5',
      worstRating: '1',
    },
  }),
};
---

<BaseLayout
  title={`${serverName} - MCP Server | MyMCPShelf`}
  description={truncatedDescription}
  canonical={canonicalUrl}
  structuredData={structuredData}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex">
    <meta name="keywords" content={`${server.fields.category || ''}, ${server.fields.language || ''}, MCP, Model Context Protocol, ${serverName}`}>
  </Fragment>

  <div class="page-container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-separator">/</span>
      <a href="/#serversGrid">Servers</a>
      {server.fields.category && (
        <>
          <span class="breadcrumb-separator">/</span>
          <a href={`/#serversGrid?category=${server.fields.category}`}>{categoryDisplay}</a>
        </>
      )}
      <span class="breadcrumb-separator">/</span>
      <span class="breadcrumb-current">{serverName}</span>
    </nav>

    <!-- Server Header -->
    <ServerHeader
      name={serverName}
      author={server.fields.author}
      stars={server.fields.stars}
      updated={server.fields.updated}
      status={server.fields.status as 'official' | 'community' | 'beta' | 'deprecated' || 'community'}
      githubUrl={server.fields.github_url}
      logoUrl={server.fields.logoUrl}
    />

    <!-- Main Content Layout -->
    <div class="content-layout">
      <main class="main-content">
        <!-- Description -->
        <section class="description-section">
          <h2>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
            Description
          </h2>
          <p class="description-text">{server.fields.description}</p>
        </section>

        <!-- Installation -->
        <ServerInstallation server={server} />

        <!-- Configuration -->
        <ServerConfiguration server={server} />

        <!-- Security Audit -->
        {auditData && auditTier && (
          <section class="security-audit-section">
            <h2>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              Security Audit
            </h2>

            <div class="audit-score-row">
              <div class="audit-score-gauge" style={`background: conic-gradient(${auditTier.color} ${auditData.auditScore * 3.6}deg, rgba(255,255,255,0.08) 0deg)`}>
                <div class="audit-score-inner">
                  <span class="score-value" style={`color: ${auditTier.color}`}>{auditData.auditScore}</span>
                  <span class="score-max">/100</span>
                </div>
              </div>
              <div class="audit-tier-info">
                <span class="tier-badge" style={`background: ${auditTier.color}22; color: ${auditTier.color}; border: 1px solid ${auditTier.color}44`}>
                  {auditTier.emoji} {auditTier.label}
                </span>
                <span class="audit-date">Audited {auditData.auditDate}</span>
                <a href="/audit-manifesto" class="methodology-link">View methodology →</a>
              </div>
            </div>

            <table class="audit-table">
              <thead>
                <tr>
                  <th>Dimension</th>
                  <th>Result</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>
                    <span class="dimension-icon">📡</span> Transport Security
                  </td>
                  <td>
                    <span class={`result-badge ${auditData.transport === 'stdio' ? 'result-good' : auditData.transport === 'both' ? 'result-warn' : 'result-risk'}`}>
                      {TRANSPORT_LABELS[auditData.transport]}
                    </span>
                  </td>
                  <td class="detail-text">Stdio is local-only process communication. SSE/HTTP exposes network attack surface.</td>
                </tr>
                <tr>
                  <td>
                    <span class="dimension-icon">🔐</span> Authentication
                  </td>
                  <td>
                    <span class={`result-badge ${auditData.authMethod === 'None' ? 'result-risk' : auditData.authMethod === 'OAuth2' || auditData.authMethod === 'SSO-SAML' ? 'result-good' : 'result-warn'}`}>
                      {AUTH_LABELS[auditData.authMethod]}
                    </span>
                  </td>
                  <td class="detail-text">{auditData.authMethod === 'None' ? 'No authentication — any client can connect.' : auditData.authMethod === 'API Key' ? 'Static API key — long-lived secret must be stored securely.' : 'Scoped tokens with expiration and refresh capabilities.'}</td>
                </tr>
                <tr>
                  <td>
                    <span class="dimension-icon">⏱️</span> Token Lifecycle
                  </td>
                  <td>
                    <span class={`result-badge ${auditData.tokenLifecycle === 'short-lived' ? 'result-good' : auditData.tokenLifecycle === 'N/A' ? 'result-neutral' : 'result-warn'}`}>
                      {TOKEN_LABELS[auditData.tokenLifecycle]}
                    </span>
                  </td>
                  <td class="detail-text">Short-lived tokens limit exposure window if compromised. Long-lived tokens require secure rotation policies.</td>
                </tr>
                <tr>
                  <td>
                    <span class="dimension-icon">🛡️</span> Input Handling
                  </td>
                  <td>
                    <span class={`result-badge ${auditData.inputHandling === 'parameterized' ? 'result-good' : auditData.inputHandling === 'mixed' ? 'result-warn' : 'result-risk'}`}>
                      {INPUT_LABELS[auditData.inputHandling]}
                    </span>
                  </td>
                  <td class="detail-text">Parameterized inputs prevent injection attacks. Shell strings enable command injection vectors.</td>
                </tr>
                <tr>
                  <td>
                    <span class="dimension-icon">🌍</span> Data Residency
                  </td>
                  <td>
                    <span class={`result-badge ${auditData.dataResidency === 'local_only' ? 'result-good' : auditData.dataResidency === 'hybrid' ? 'result-warn' : auditData.dataResidency === 'cloud' ? 'result-risk' : 'result-neutral'}`}>
                      {RESIDENCY_LABELS[auditData.dataResidency]}
                    </span>
                  </td>
                  <td class="detail-text">Local-only data never leaves your machine. Cloud residency means data flows through third-party APIs.</td>
                </tr>
              </tbody>
            </table>

            {auditData.auditorNotes && (
              <div class="auditor-notes">
                <strong>Auditor Notes:</strong> {auditData.auditorNotes}
              </div>
            )}
          </section>
        )}

        <!-- Green Hosting Score -->
        {greenScore && greenScore.tier !== 'unknown' && (
          <section class="green-score-section">
            <h2>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
                <path d="M2 12h20"></path>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
              Green Hosting
            </h2>

            <div class="green-tier-row">
              <div class="green-badge-large">
                <GreenBadge client:load greenScore={greenScore} />
              </div>
              <div class="green-tier-info">
                <p class="green-description">{greenScore.description}</p>
                {greenScore.hostingProvider && (
                  <span class="green-provider">Hosting: {greenScore.hostingProvider}</span>
                )}
                <a href="/green-hosting" class="methodology-link">Which platforms are green-verified? →</a>
              </div>
            </div>
          </section>
        )}

        <!-- Available Tools -->
        {server.fields.available_tools && server.fields.available_tools.length > 0 && (
          <ServerTools tools={server.fields.available_tools} />
        )}

        <!-- Prerequisites -->
        {server.fields.prerequisites && server.fields.prerequisites.length > 0 && (
          <section class="prerequisites-section">
            <h2>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 11 12 14 22 4"></polyline>
                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
              </svg>
              Prerequisites
            </h2>
            <ul class="prerequisites-list">
              {server.fields.prerequisites.map(prereq => (
                <li>{prereq}</li>
              ))}
            </ul>
          </section>
        )}

        <!-- Environment Variables -->
        {server.fields.environment_variables && server.fields.environment_variables.length > 0 && (
          <section class="env-vars-section">
            <h2>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
              </svg>
              Environment Variables
            </h2>
            <table class="env-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Description</th>
                  <th>Required</th>
                  <th>Default</th>
                </tr>
              </thead>
              <tbody>
                {server.fields.environment_variables.map(envVar => (
                  <tr>
                    <td><code>{envVar.name}</code></td>
                    <td>{envVar.description}</td>
                    <td>
                      <span class={`required-badge ${envVar.required ? 'yes' : 'no'}`}>
                        {envVar.required ? 'Yes' : 'No'}
                      </span>
                    </td>
                    <td>{envVar.default || '-'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        )}
      </main>

      <!-- Sidebar -->
      <aside class="sidebar">
        <ServerMetadata server={server} />
        {server.fields.github_url && (
          <GitHubHealthVitals
            client:load
            githubUrl={server.fields.github_url}
            token={import.meta.env.GITHUB_TOKEN}
          />
        )}
        <RelatedServers servers={relatedServers} currentServerId={server.id} />
        <CustomMcpCta variant="compact" />
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #94a3b8;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover { color: #f59e0b; }

  .breadcrumb-separator {
    color: #94a3b8;
    opacity: 0.5;
  }

  .breadcrumb-current {
    color: #f1f5f9;
    font-weight: 500;
  }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    margin-top: 1.5rem;
  }

  .main-content { min-width: 0; }

  .description-section,
  .prerequisites-section,
  .env-vars-section {
    background: rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .description-section h2,
  .prerequisites-section h2,
  .env-vars-section h2 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0 0 1rem 0;
  }

  .description-section h2 svg,
  .prerequisites-section h2 svg,
  .env-vars-section h2 svg {
    color: #94a3b8;
  }

  .description-text {
    color: #94a3b8;
    line-height: 1.8;
    font-size: 1rem;
  }

  .prerequisites-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .prerequisites-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: #94a3b8;
  }

  .prerequisites-list li::before {
    content: '•';
    color: #f59e0b;
    font-weight: bold;
    font-size: 1.2rem;
    line-height: 1;
  }

  .env-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .env-table th {
    text-align: left;
    padding: 0.75rem;
    background: rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    font-weight: 600;
    color: #f1f5f9;
  }

  .env-table td {
    padding: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    color: #94a3b8;
  }

  .env-table code {
    background: rgba(255,255,255,0.08);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
    font-size: 0.85rem;
    color: #f59e0b;
  }

  .required-badge {
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .required-badge.yes {
    background: rgba(239,68,68,0.1);
    color: #ef4444;
  }

  .required-badge.no {
    background: rgba(34,197,94,0.1);
    color: #22c55e;
  }

  /* Security Audit Section */
  .security-audit-section {
    background: rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .security-audit-section h2 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: #f1f5f9;
    margin: 0 0 1.25rem 0;
  }

  .security-audit-section h2 svg {
    color: #94a3b8;
  }

  .audit-score-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .audit-score-gauge {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .audit-score-inner {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #1e293b;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .score-value {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
  }

  .score-max {
    font-size: 0.75rem;
    color: #64748b;
  }

  .audit-tier-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .tier-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
    width: fit-content;
  }

  .audit-date {
    font-size: 0.8rem;
    color: #64748b;
  }

  .methodology-link {
    font-size: 0.8rem;
    color: #f59e0b;
    text-decoration: none;
    transition: color 0.15s;
  }

  .methodology-link:hover { color: #fbbf24; }

  .audit-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .audit-table th {
    text-align: left;
    padding: 0.75rem;
    background: rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    font-weight: 600;
    color: #f1f5f9;
  }

  .audit-table td {

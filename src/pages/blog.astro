---
export const prerender = true;
import { getCollection } from 'astro:content';
import HeaderNewsletter from '../components/HeaderNewsletter.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Get all blog posts
const blogPosts = await getCollection('blog');

// Sort by date (newest first)
const sortedPosts = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const pageTitle = "My MCP Shelf Blog";
---

<BaseLayout
  title={pageTitle}
  description="Insights, updates, and guides for the MCP ecosystem"
  canonical="https://www.mymcpshelf.com/blog"
>
  <div class="container">
    <section class="hero-section">
      <h1 class="hero-title">{pageTitle}</h1>
      <p class="hero-subtitle">Insights, updates, and guides for the MCP ecosystem</p>

      <div class="stats-bar">
        <div class="stat-item">
          <div class="stat-value">{sortedPosts.length}</div>
          <div class="stat-label">Articles</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">Weekly</div>
          <div class="stat-label">Updates</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">Expert</div>
          <div class="stat-label">Authors</div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <div style="margin-top: 1.5rem; display: flex; justify-content: center;">
      <HeaderNewsletter />
    </div>

    <main>
      {sortedPosts.length > 0 ? (
        <div class="blog-grid">
          {sortedPosts.map((post) => (
            <article class="blog-card">
              <h3>
                <a href={`/blog/${post.slug}`}>
                  {post.data.title}
                </a>
              </h3>
              <div class="blog-meta">
                By {post.data.author} • {new Date(post.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </div>
              <p class="blog-description">
                {post.data.description}
              </p>
              {post.data.tags && (
                <div class="blog-tags">
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      ) : (
        <p class="no-posts">No blog posts available yet. Check back soon!</p>
      )}
    </main>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero-section {
    text-align: center;
    margin-bottom: 2rem;
    padding: 2rem 0;
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, #f59e0b 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1rem;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f59e0b;
  }

  .stat-label {
    font-size: 0.9rem;
    color: #64748b;
  }

  .blog-grid {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  .blog-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 2rem;
    border: 1px solid #e2e8f0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
  }

  .blog-card h3 {
    color: #0f172a;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .blog-card h3 a {
    text-decoration: none;
    color: inherit;
  }

  .blog-card h3 a:hover {
    color: #f59e0b;
  }

  .blog-meta {
    color: #475569;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .blog-description {
    color: #334155;
    margin-bottom: 1rem;
  }

  .blog-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
    padding: 0.25rem 0.75rem;
    border-radius: 15px;
    font-size: 0.8rem;
  }

  .no-posts {
    text-align: center;
    color: #334155;
    font-size: 1.1rem;
    margin-top: 2rem;
  }

  @media (max-width: 768px) {
    .container { padding: 1rem; }
    .hero-title { font-size: 2rem; }
  }
</style>

---
import { getServersPage } from '../utils/d1';
import type { MCPServer } from '../utils/d1';
import ServerGrid from '../components/ServerGrid';
import { filterServersByDeployment } from '../utils/serverData.js';
import { staticServers } from '../data/staticServers.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/deployment-page.css';

const DEPLOYMENT_CONFIG = {
  deploymentType: 'local_stdio',
  title: 'Local & CLI MCP Servers',
  subtitle: 'stdio-based local development tools',
  description: 'Browse MCP servers designed for local development and CLI-based workflows. These servers communicate via stdin/stdout and are perfect for development environments, testing, and self-hosted deployment where direct process communication is preferred.',
  heroTitle: 'MCP Servers for Local Development',
  heroDescription: 'Discover MCP servers optimized for local development, CLI tools, and stdio-based communication. Perfect for development environments, offline usage, and self-hosted deployment.',
  tagline: 'Run locally, deploy anywhere',
  features: [
    'No internet required after installation',
    'Direct process communication via stdio',
    'Perfect for development and testing',
    'Easy debugging and troubleshooting',
    'Full control over data and execution',
    'Works offline and in air-gapped environments',
  ],
  requirements: [
    'Local runtime environment (Node.js/Python)',
    'CLI access and command-line tools',
    'Basic understanding of process management',
  ],
  useCases: [
    'Local development workflows',
    'CI/CD pipeline integration',
    'Testing and debugging MCP tools',
    'Offline or air-gapped environments',
    'Self-hosted deployment scenarios',
    'Data-sensitive operations',
  ],
};

const db = (Astro.locals as any).runtime?.env?.DB as D1Database | undefined;
let initialServers: MCPServer[] = [];
let total = 0;

if (db) {
  try {
    const result = await getServersPage(db, { limit: 48, deployment: DEPLOYMENT_CONFIG.deploymentType });
    initialServers = result.servers;
    total = result.total;
  } catch (error) {
    console.error(`Error fetching servers for ${DEPLOYMENT_CONFIG.deploymentType}:`, error);
  }
} else {
  const filteredServers = filterServersByDeployment(staticServers as any[] as MCPServer[], DEPLOYMENT_CONFIG.deploymentType);
  initialServers = filteredServers.slice(0, 48);
  total = filteredServers.length;
}

const canonicalUrl = 'https://www.mymcpshelf.com/local-stdio';
const pageTitle = `${DEPLOYMENT_CONFIG.title} | My MCP Shelf`;
const pageDescription = `${DEPLOYMENT_CONFIG.description} Browse ${total}+ MCP servers optimized for local stdio deployment.`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: DEPLOYMENT_CONFIG.title,
  description: pageDescription,
  url: canonicalUrl,
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  structuredData={structuredData}
>
  <div transition:name="main-content">
    <section class="hero-section">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="page-title">{DEPLOYMENT_CONFIG.heroTitle}</h1>
          <p class="page-subtitle">{DEPLOYMENT_CONFIG.heroDescription}</p>
          <div class="tagline-badge">
            <span>⚡</span>
            {DEPLOYMENT_CONFIG.tagline}
          </div>
        </div>
        <div class="hero-badges">
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-value">{total}</span>
              <span class="stat-label">Servers</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">100%</span>
              <span class="stat-label">Offline</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">Free</span>
              <span class="stat-label">To Use</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main class="page-container">
      <section class="deployment-info">
        <h2>About {DEPLOYMENT_CONFIG.title}</h2>
        <p>{DEPLOYMENT_CONFIG.description}</p>
        <div class="info-grid">
          <div class="info-section">
            <h3>✨ Key Features</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.features.map(f => <li>{f}</li>)}
            </ul>
          </div>
          <div class="info-section">
            <h3>⚙️ Requirements</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.requirements.map(r => <li>{r}</li>)}
            </ul>
          </div>
          <div class="info-section">
            <h3>💡 Use Cases</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.useCases.map(u => <li>{u}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="grid-section">
        <div class="section-header">
          <div>
            <h2 class="section-title">{initialServers.length > 0 ? `${total}+ ${DEPLOYMENT_CONFIG.title}` : 'Browse Servers'}</h2>
            <p class="section-description">Discover the best MCP servers optimized for {DEPLOYMENT_CONFIG.subtitle}</p>
          </div>
        </div>
        {initialServers.length > 0 ? (
          <ServerGrid client:load initialServers={initialServers} total={total} meta={{ deployment: DEPLOYMENT_CONFIG.deploymentType }} />
        ) : (
          <div class="no-results">
            <h3>No servers found for this deployment type yet</h3>
            <p>Check back soon or <a href="/submit-server">submit a new server</a>.</p>
          </div>
        )}
      </section>

      <section class="comparison-section">
        <h2>Not sure which deployment is right for you?</h2>
        <p>Compare deployment options and find the best fit for your infrastructure needs.</p>
        <div class="comparison-cta">
          <a href="/enterprise-readiness" class="btn">Compare Deployment Options →</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

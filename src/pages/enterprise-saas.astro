---
import { getServersPage } from '../utils/d1';
import type { MCPServer } from '../utils/d1';
import ServerGrid from '../components/ServerGrid';
import { filterServersByDeployment } from '../utils/serverData.js';
import { staticServers } from '../data/staticServers.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/deployment-page.css';

const DEPLOYMENT_CONFIG = {
  deploymentType: 'enterprise_saas',
  title: 'Enterprise SaaS MCP Servers',
  subtitle: 'secure managed SaaS with SLAs',
  description: 'Production-ready MCP servers with enterprise features like SSO, audit logs, SLAs, and dedicated support. Perfect for mission-critical applications requiring compliance, security, and scalability guarantees.',
  heroTitle: 'Enterprise SaaS MCP Servers',
  heroDescription: 'Deploy production-ready MCP servers with enterprise-grade security, compliance, and support. Perfect for mission-critical applications requiring reliability and scalability at scale.',
  tagline: 'Enterprise-ready from day one',
  features: [
    'SSO and SAML authentication support',
    'Enterprise-grade audit logs and compliance',
    '99.9%+ SLA guarantees',
    'Dedicated support and onboarding',
    'SOC 2 Type II certified infrastructure',
    'Automatic scaling and load balancing',
    'Advanced security and threat detection',
    'Role-based access control (RBAC)',
  ],
  requirements: [
    'Enterprise contract and agreement',
    'SSO/SAML identity provider configuration',
    'Dedicated infrastructure provisioning',
    'Security and compliance review',
    'Support agreement and SLA definition',
  ],
  useCases: [
    'Mission-critical business applications',
    'Large-scale enterprise deployments',
    'Regulated industries (finance, healthcare, gov)',
    'Multi-tenant SaaS platforms',
    'Global distributed teams',
    'High-availability requirements',
  ],
};

const db = (Astro.locals as any).runtime?.env?.DB as D1Database | undefined;
let initialServers: MCPServer[] = [];
let total = 0;

if (db) {
  try {
    const result = await getServersPage(db, { limit: 48, deployment: DEPLOYMENT_CONFIG.deploymentType });
    initialServers = result.servers;
    total = result.total;
  } catch (error) {
    console.error(`Error fetching servers for ${DEPLOYMENT_CONFIG.deploymentType}:`, error);
  }
} else {
  const filteredServers = filterServersByDeployment(staticServers as any[] as MCPServer[], DEPLOYMENT_CONFIG.deploymentType);
  initialServers = filteredServers.slice(0, 48);
  total = filteredServers.length;
}

const canonicalUrl = 'https://www.mymcpshelf.com/enterprise-saas';
const pageTitle = `${DEPLOYMENT_CONFIG.title} | My MCP Shelf`;
const pageDescription = `${DEPLOYMENT_CONFIG.description} Browse ${total}+ enterprise MCP servers.`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: DEPLOYMENT_CONFIG.title,
  description: pageDescription,
  url: canonicalUrl,
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  structuredData={structuredData}
>
  <div transition:name="main-content">
    <section class="hero-section">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="page-title">{DEPLOYMENT_CONFIG.heroTitle}</h1>
          <p class="page-subtitle">{DEPLOYMENT_CONFIG.heroDescription}</p>
          <div class="tagline-badge">
            <span>🔐</span>
            {DEPLOYMENT_CONFIG.tagline}
          </div>
        </div>
        <div class="hero-badges">
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-value">{total}</span>
              <span class="stat-label">Servers</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">SOC2</span>
              <span class="stat-label">Certified</span>
            </div>
            <div class="stat-card">
              <span class="stat-value">99.9%</span>
              <span class="stat-label">SLA</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main class="page-container">
      <section class="deployment-info">
        <h2>About {DEPLOYMENT_CONFIG.title}</h2>
        <p>{DEPLOYMENT_CONFIG.description}</p>
        <div class="info-grid">
          <div class="info-section">
            <h3>✨ Key Features</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.features.map(f => <li>{f}</li>)}
            </ul>
          </div>
          <div class="info-section">
            <h3>⚙️ Requirements</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.requirements.map(r => <li>{r}</li>)}
            </ul>
          </div>
          <div class="info-section">
            <h3>💡 Use Cases</h3>
            <ul class="info-list">
              {DEPLOYMENT_CONFIG.useCases.map(u => <li>{u}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="grid-section">
        <div class="section-header">
          <div>
            <h2 class="section-title">{initialServers.length > 0 ? `${total}+ ${DEPLOYMENT_CONFIG.title}` : 'Browse Servers'}</h2>
            <p class="section-description">Discover the best MCP servers optimized for {DEPLOYMENT_CONFIG.subtitle}</p>
          </div>
        </div>
        {initialServers.length > 0 ? (
          <ServerGrid client:load initialServers={initialServers} total={total} meta={{ deployment: DEPLOYMENT_CONFIG.deploymentType }} />
        ) : (
          <div class="no-results">
            <h3>No servers found for this deployment type yet</h3>
            <p>Check back soon or <a href="/submit-server">submit a new server</a>.</p>
          </div>
        )}
      </section>

      <section class="comparison-section">
        <h2>Not sure which deployment is right for you?</h2>
        <p>Compare deployment options and find the best fit for your infrastructure needs.</p>
        <div class="comparison-cta">
          <a href="/enterprise-readiness" class="btn">Compare Deployment Options →</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'How We Calculate Green Scores | MyMCPShelf';
const pageDescription = 'Full methodology for MCP server green hosting assessment. Verified vs. Estimated tiers, data sources, API references, update frequency, and limitations.';
const canonicalUrl = 'https://www.mymcpshelf.com/green-scores';

const tiers = [
  {
    id: 'green_verified',
    label: 'Green Verified',
    emoji: '🌿',
    color: '#10b981',
    description: 'The Greencheck API confirms the server\'s hosting provider runs on verified renewable-energy infrastructure. This is a direct, auditable claim — not an estimate.',
    dataSources: ['Green Web Foundation Greencheck API v3'],
    credibility: 'High — third-party verified, annually recertified by Green Web Foundation.',
  },
  {
    id: 'green_estimated',
    label: 'Green Estimated',
    emoji: '📊',
    color: '#f59e0b',
    description: 'The server\'s IP address is resolved to a geographic location, and the regional average grid carbon intensity (gCO2/kWh) is retrieved. This is an estimate — it does NOT mean the host uses renewable energy, only that the regional grid has a certain carbon profile.',
    dataSources: ['Green Web Foundation IP-to-CO2 API v2', 'Google DNS for IP resolution'],
    credibility: 'Moderate — reflects regional grid averages, not the actual hosting provider\'s energy procurement.',
  },
  {
    id: 'user_dependent',
    label: 'User-Dependent',
    emoji: '💻',
    color: '#818cf8',
    description: 'stdio/local servers run on the user\'s own machine. Their carbon footprint is determined by the user\'s own energy source — which we cannot know. This tier avoids false claims by explicitly stating the dependency.',
    dataSources: ['None — inferred from stdio deployment type'],
    credibility: 'Transparent — no claim made, dependency made explicit.',
  },
];

const dataSources = [
  {
    name: 'Greencheck API v3',
    provider: 'Green Web Foundation',
    url: 'https://developers.thegreenwebfoundation.org/api/greencheck/v3/check-single-domain/',
    method: 'Domain lookup against a curated database of green hosting providers',
    updateFrequency: 'Green Web Foundation updates their database continuously; we refresh weekly',
    limitations: 'Only covers hosting providers in their database. Self-hosted or small providers may not be listed even if they use green energy.',
  },
  {
    name: 'IP-to-CO2 Intensity API v2',
    provider: 'Green Web Foundation',
    url: 'https://developers.thegreenwebfoundation.org/api/ip-to-co2/overview/',
    method: 'Resolves server IP → geographic location → regional average annual grid intensity (gCO2/kWh)',
    updateFrequency: 'Annual grid intensity data updated yearly; we refresh weekly',
    limitations: 'Uses average annual grid intensity, not real-time or marginal values. Does not reflect the hosting provider\'s actual energy procurement (PPAs, RECs, on-site generation). CDN/anycast IPs may resolve to incorrect regions.',
  },
];

const limitations = [
  'CDN and anycast IPs may resolve to edge nodes that don\'t reflect the actual origin server location.',
  'Annual average grid intensity doesn\'t capture temporal variation (night vs. day, seasonal wind/solar output).',
  'A "Green Estimated" label with low gCO2/kWh does NOT mean the hosting provider uses renewable energy — it means the regional grid happens to be cleaner than average.',
  'Small or self-hosted providers using 100% renewable energy won\'t appear as "Green Verified" unless they\'re registered with the Green Web Foundation.',
  'GitHub Pages, Vercel, Netlify, and Cloudflare Pages domains resolve to shared infrastructure — the green status applies to the platform, not the specific project.',
  'We check up to 500 servers weekly, prioritized by popularity. Newer or less popular servers may have stale data.',
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How We Calculate Green Scores for MCP Servers",
  "description": pageDescription,
  "url": canonicalUrl,
  "step": tiers.map((t, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": t.label,
    "text": t.description,
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  structuredData={structuredData}
>
  <div class="page-wrapper">
    <section class="hero-section">
      <div class="hero-content">
        <h1 class="page-title">How We Calculate Green Scores</h1>
        <p class="page-subtitle">
          Full methodology, data sources, and the Verified vs. Estimated distinction.
          Transparency prevents greenwashing. Evidence enables enterprise trust.
        </p>
        <div class="hero-badges">
          <span class="hero-badge">🌿 Verified</span>
          <span class="hero-badge">📊 Estimated</span>
          <span class="hero-badge">💻 User-Dependent</span>
          <span class="hero-badge">Weekly Refresh</span>
        </div>
      </div>
    </section>

    <main class="page-container">
      <!-- Why Two Tiers -->
      <section class="section">
        <h2 class="section-title">Verified vs. Estimated: Why the Distinction Matters</h2>
        <p class="section-description">
          Enterprise ESG teams need defensible claims. A single "green" badge without
          supporting evidence is greenwashing. By splitting badges into <strong>Verified</strong>
          (third-party confirmed renewable infrastructure) and <strong>Estimated</strong>
          (regional grid data), compliance teams can trace every claim to a specific data source.
        </p>
        <div class="distinction-grid">
          <div class="distinction-card verified">
            <span class="distinction-icon">🌿</span>
            <h3>Green Verified</h3>
            <p>Greencheck API confirms hosting on <strong>verified renewable-energy infrastructure</strong>. The hosting provider has been audited and certified by the Green Web Foundation.</p>
            <span class="distinction-claim">Claim: "This server runs on confirmed green infrastructure"</span>
          </div>
          <div class="distinction-card estimated">
            <span class="distinction-icon">📊</span>
            <h3>Green Estimated</h3>
            <p>Carbon intensity is <strong>calculated from regional grid data</strong> based on IP geolocation. Displayed as estimated gCO2/kWh with region name. NOT a verification of renewable energy.</p>
            <span class="distinction-claim">Claim: "This server's region averages X gCO2/kWh on the grid"</span>
          </div>
          <div class="distinction-card user-dependent">
            <span class="distinction-icon">💻</span>
            <h3>User-Dependent</h3>
            <p>stdio/local servers run on <strong>your machine</strong>. Their carbon footprint depends on your own energy source. We make no claim — we just state the dependency.</p>
            <span class="distinction-claim">Claim: "Carbon footprint depends on the user's energy source"</span>
          </div>
        </div>
      </section>

      <!-- Assessment Process -->
      <section class="section">
        <h2 class="section-title">Assessment Process</h2>
        <div class="steps-grid">
          <div class="step">
            <span class="step-number">1</span>
            <div>
              <h3>Classify Deployment</h3>
              <p>stdio/local servers are immediately classified as User-Dependent. No API calls needed.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">2</span>
            <div>
              <h3>Extract Domain</h3>
              <p>For remote servers, extract the domain from the server's GitHub URL or homepage URL.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">3</span>
            <div>
              <h3>Greencheck API</h3>
              <p>Query <code>api.thegreenwebfoundation.org/v3/greencheck/{domain}</code>. If <code>green: true</code>, assign Green Verified tier.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">4</span>
            <div>
              <h3>IP-to-CO2 API</h3>
              <p>If not Green Verified, resolve domain → IP via Google DNS, then query <code>api.thegreenwebfoundation.org/v2/ip-to-co2intensity/{ip}</code> for regional grid intensity.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">5</span>
            <div>
              <h3>Assign Tier</h3>
              <p>Green Verified → verified badge. Carbon intensity data → Estimated badge with gCO2/kWh and region. No data → Unknown (badge not shown).</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">6</span>
            <div>
              <h3>Store & Display</h3>
              <p>Results stored as JSON in D1 database. Badges rendered on server cards and detail pages. Updated weekly.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Tier Details -->
      <section class="section">
        <h2 class="section-title">Tier Details</h2>
        <div class="tiers-detail-grid">
          {tiers.map(tier => (
            <div class="tier-detail-card" style={`border-left: 4px solid ${tier.color}`}>
              <div class="tier-detail-header">
                <span class="tier-emoji">{tier.emoji}</span>
                <h3 style={`color: ${tier.color}`}>{tier.label}</h3>
              </div>
              <p class="tier-detail-desc">{tier.description}</p>
              <div class="tier-detail-meta">
                <div>
                  <strong>Data Sources:</strong>
                  <ul>{tier.dataSources.map(s => <li>{s}</li>)}</ul>
                </div>
                <div>
                  <strong>Credibility:</strong> {tier.credibility}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Data Sources -->
      <section class="section">
        <h2 class="section-title">Data Sources</h2>
        <div class="sources-grid">
          {dataSources.map(source => (
            <div class="source-card">
              <h3>{source.name}</h3>
              <p class="source-provider">by {source.provider}</p>
              <a href={source.url} class="source-url" target="_blank" rel="noopener noreferrer">API Documentation →</a>
              <div class="source-details">
                <div><strong>Method:</strong> {source.method}</div>
                <div><strong>Update Frequency:</strong> {source.updateFrequency}</div>
                <div><strong>Limitations:</strong> {source.limitations}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Limitations -->
      <section class="section">
        <h2 class="section-title">Known Limitations</h2>
        <ul class="limitations-list">
          {limitations.map(lim => (
            <li>{lim}</li>
          ))}
        </ul>
      </section>

      <!-- Update Frequency -->
      <section class="section">
        <h2 class="section-title">Update Frequency & Infrastructure</h2>
        <div class="info-grid">
          <div class="info-card">
            <h3>Schedule</h3>
            <p>Weekly, every Monday at 03:00 UTC. Top 500 servers by popularity are assessed each cycle.</p>
          </div>
          <div class="info-card">
            <h3>Infrastructure</h3>
            <p>Runs as a Cloudflare Worker with Cron Triggers — same platform as the site, writes directly to the D1 database. No external CI/CD dependency.</p>
          </div>
          <div class="info-card">
            <h3>Rate Limits</h3>
            <p>We process servers in batches of 20 with 1-second pauses between batches to respect API rate limits. ~1000 API calls per weekly run.</p>
          </div>
        </div>
      </section>

      <!-- Self-Attestation -->
      <section class="section">
        <h2 class="section-title">Self-Attestation for Server Authors</h2>
        <p class="section-description">
          If your server runs on verified green infrastructure but doesn't appear as "Green Verified",
          your hosting provider may not be registered with the Green Web Foundation. You can:
        </p>
        <div class="attestation-steps">
          <div class="attestation-item">
            <strong>1.</strong> Ask your hosting provider to register with the <a href="https://www.thegreenwebfoundation.org/directory/" target="_blank" rel="noopener noreferrer">Green Web Foundation Directory</a>.
          </div>
          <div class="attestation-item">
            <strong>2.</strong> Once registered, our next weekly scan will automatically detect and update your badge.
          </div>
          <div class="attestation-item">
            <strong>3.</strong> If you self-host on renewable energy, document your energy source in your README — we review these manually during spot-checks.
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="cta-section">
        <h2 class="cta-title">Explore Servers with Green Scores</h2>
        <p class="cta-description">
          Browse MCP servers with transparent green hosting data. Filter by Green Verified, Estimated, or Local-Only.
        </p>
        <div class="cta-buttons">
          <a href="/" class="btn-white">Browse Servers</a>
          <a href="/audit-manifesto" class="btn-outline-white">Security Audit Methodology →</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .page-wrapper { min-height: 100vh; display: flex; flex-direction: column; }
  .hero-section {
    background: linear-gradient(135deg, #0f172a 0%, #064e3b 50%, #334155 100%);
    padding: 4rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    text-align: center;
  }
  .hero-content { max-width: 800px; margin: 0 auto; padding: 0 1.5rem; }
  .page-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; margin-bottom: 1rem;
    background: linear-gradient(135deg, #ffffff 0%, #10b981 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .page-subtitle { font-size: 1.2rem; color: #94a3b8; margin-bottom: 2rem; line-height: 1.7; }
  .hero-badges { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .hero-badge {
    background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3);
    color: #10b981; padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600;
  }
  .page-container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; flex: 1; }
  .section { margin: 3rem 0; }
  .section-title { font-size: 2rem; font-weight: 600; margin-bottom: 1rem; text-align: center; color: #f1f5f9; }
  .section-description { font-size: 1.1rem; color: #94a3b8; text-align: center; margin-bottom: 2.5rem; max-width: 800px; margin-left: auto; margin-right: auto; line-height: 1.7; }
  .section-description strong { color: #f1f5f9; }

  /* Distinction Cards */
  .distinction-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .distinction-card {
    background: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.5rem;
  }
  .distinction-card.verified { border-top: 3px solid #10b981; }
  .distinction-card.estimated { border-top: 3px solid #f59e0b; }
  .distinction-card.user-dependent { border-top: 3px solid #818cf8; }
  .distinction-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .distinction-card h3 { font-size: 1.15rem; color: #f1f5f9; margin: 0 0 0.75rem; }
  .distinction-card p { color: #94a3b8; font-size: 0.9rem; line-height: 1.6; margin: 0 0 1rem; }
  .distinction-card strong { color: #f1f5f9; }
  .distinction-claim { font-size: 0.8rem; color: #64748b; font-style: italic; }

  /* Steps */
  .steps-grid { display: grid; gap: 1rem; max-width: 700px; margin: 0 auto; }
  .step {
    display: flex; align-items: flex-start; gap: 1rem;
    background: #1e293b; border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px; padding: 1.25rem;
  }
  .step-number {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #10b981, #059669);
    color: white; display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 1rem; flex-shrink: 0;
  }
  .step h3 { font-size: 1rem; color: #f1f5f9; margin: 0 0 0.35rem; }
  .step p { color: #94a3b8; font-size: 0.875rem; margin: 0; line-height: 1.6; }
  .step code { background: rgba(255,255,255,0.08); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.8rem; color: #10b981; }

  /* Tier Details */
  .tiers-detail-grid { display: grid; gap: 1.5rem; }
  .tier-detail-card { background: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.5rem; }
  .tier-detail-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .tier-emoji { font-size: 1.5rem; }
  .tier-detail-header h3 { font-size: 1.15rem; margin: 0; }
  .tier-detail-desc { color: #94a3b8; font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem; }
  .tier-detail-meta { font-size: 0.85rem; color: #94a3b8; }
  .tier-detail-meta strong { color: #f1f5f9; }
  .tier-detail-meta ul { margin: 0.25rem 0; padding-left: 1.25rem; }
  .tier-detail-meta li { margin-bottom: 0.15rem; }

  /* Data Sources */
  .sources-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; }
  .source-card {
    background: #1e293b; border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px; padding: 1.5rem;
  }
  .source-card h3 { font-size: 1.1rem; color: #10b981; margin: 0 0 0.25rem; }
  .source-provider { color: #64748b; font-size: 0.85rem; margin: 0 0 0.75rem; }
  .source-url { color: #f59e0b; font-size: 0.85rem; text-decoration: none; }
  .source-url:hover { color: #fbbf24; }
  .source-details { font-size: 0.85rem; color: #94a3b8; margin-top: 1rem; }
  .source-details strong { color: #f1f5f9; }
  .source-details div { margin-bottom: 0.5rem; }

  /* Limitations */
  .limitations-list { max-width: 800px; margin: 0 auto; list-style: none; padding: 0; }
  .limitations-list li {
    padding: 0.75rem 1rem; margin-bottom: 0.5rem;
    background: #1e293b; border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; color: #94a3b8; font-size: 0.9rem; line-height: 1.5;
  }
  .limitations-list li::before { content: '⚠️'; margin-right: 0.5rem; }

  /* Info Cards */
  .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .info-card { background: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.5rem; }
  .info-card h3 { font-size: 1.1rem; color: #10b981; margin-bottom: 0.5rem; }
  .info-card p { color: #94a3b8; font-size: 0.9rem; line-height: 1.6; }

  /* Attestation */
  .attestation-steps { max-width: 700px; margin: 0 auto; }
  .attestation-item {
    padding: 0.75rem 1rem; margin-bottom: 0.5rem;
    background: #1e293b; border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; color: #94a3b8; font-size: 0.9rem; line-height: 1.5;
  }
  .attestation-item a { color: #10b981; text-decoration: none; }
  .attestation-item a:hover { color: #34d399; }

  /* CTA */
  .cta-section {
    background: linear-gradient(135deg, #064e3b 0%, #10b981 100%);
    border-radius: 12px; padding: 3rem; text-align: center; color: white; margin: 3rem 0;
  }
  .cta-title { font-size: 2rem; font-weight: 600; margin-bottom: 1rem; }
  .cta-description { font-size: 1.1rem; margin-bottom: 2rem; opacity: 0.9; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-white {
    background: white; color: #064e3b; padding: 0.75rem 2rem; border-radius: 8px;
    text-decoration: none; font-weight: 600; transition: all 0.15s ease;
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(255,255,255,0.25); }
  .btn-outline-white {
    background: transparent; color: white; border: 2px solid white;
    padding: 0.75rem 2rem; border-radius: 8px; text-decoration: none;
    font-weight: 600; transition: all 0.15s ease;
  }
  .btn-outline-white:hover { background: white; color: #064e3b; }

  @media (max-width: 768px) {
    .page-title { font-size: 2rem; }
    .hero-badges { gap: 0.5rem; }
    .cta-buttons { flex-direction: column; }
    .btn-white, .btn-outline-white { width: 100%; }
  }
</style>

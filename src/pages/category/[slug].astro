---
import { getServersPage } from '../../utils/d1';
import type { MCPServer } from '../../utils/d1';
import { getCategoryDisplayName } from '../../utils/serverData.js';
import { staticServers } from '../../data/staticServers.js';
import ServerGrid from '../../components/ServerGrid';
import BaseLayout from '../../layouts/BaseLayout.astro';

const { slug } = Astro.params;
const categoryName = getCategoryDisplayName(slug);
const db = (Astro.locals as any).runtime?.env?.DB as D1Database | undefined;

let servers: MCPServer[] = [];
let total = 0;

if (db) {
  try {
    const result = await getServersPage(db, { category: slug, limit: 48 });
    servers = result.servers;
    total = result.total;
  } catch (error) {
    console.error(`Error fetching servers for category ${slug}:`, error);
  }
} else {
  const all = staticServers as any[] as MCPServer[];
  servers = all.filter(s => s.fields?.category === slug).slice(0, 48);
  total = servers.length;
}

const canonicalUrl = `https://www.mymcpshelf.com/category/${slug}`;
const pageTitle = `${categoryName} MCP Servers | My MCP Shelf`;
const pageDescription = `Browse ${total}+ MCP servers in the ${categoryName} category. Find the best tools for your workflow.`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={canonicalUrl}>
  <div transition:name="main-content">
    <div class="hero-section">
      <div class="hero-content">
        <div class="breadcrumb">
          <a href="/">Home</a>
          <span>›</span>
          <span>Categories</span>
          <span>›</span>
          <span>{categoryName}</span>
        </div>
        <h1 class="page-title">{categoryName} MCP Servers</h1>
        <p class="page-subtitle">Browse MCP servers in the {categoryName} category</p>
        <span class="server-count">{total} server{total !== 1 ? 's' : ''}</span>
      </div>
    </div>

    <div class="main-content">
      <div class="category-nav">
        {[
          { slug: 'databases', label: 'Databases' },
          { slug: 'cloud', label: 'Cloud & Infrastructure' },
          { slug: 'ai-tools', label: 'AI Tools' },
          { slug: 'development', label: 'Development' },
          { slug: 'productivity', label: 'Productivity' },
          { slug: 'communication', label: 'Communication' },
          { slug: 'security', label: 'Security' },
          { slug: 'search', label: 'Search' },
          { slug: 'browser-automation', label: 'Browser Automation' },
          { slug: 'knowledge-rag', label: 'Knowledge & RAG' },
        ].map(cat => (
          <a
            href={`/category/${cat.slug}`}
            class:list={['category-link', { active: cat.slug === slug }]}
          >
            {cat.label}
          </a>
        ))}
      </div>

      {servers.length > 0 ? (
        <ServerGrid
          client:load
          initialServers={servers}
          total={total}
          meta={{ category: slug }}
        />
      ) : (
        <div class="empty-state">
          <h2>No servers found in {categoryName}</h2>
          <p>Try <a href="/">browsing all servers</a> or check another category.</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .hero-section {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    padding: 3rem 0 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }

  .breadcrumb a {
    color: #94a3b8;
    text-decoration: none;
  }

  .breadcrumb a:hover { color: #f59e0b; }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: #94a3b8;
  }

  .server-count {
    display: inline-block;
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.3);
    padding: 0.4rem 0.9rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 1rem;
  }

  .main-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .category-link {
    padding: 0.4rem 0.9rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    color: #94a3b8;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    transition: all 0.15s ease;
  }

  .category-link:hover,
  .category-link.active {
    color: #f59e0b;
    border-color: rgba(245, 158, 11, 0.4);
    background: rgba(245, 158, 11, 0.1);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    color: #64748b;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    color: #94a3b8;
    margin-bottom: 0.75rem;
  }

  .empty-state a {
    color: #f59e0b;
    text-decoration: none;
  }
</style>

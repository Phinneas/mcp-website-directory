---
import { getServersPage, getFeaturedServers } from '../utils/d1';
import type { MCPServer } from '../utils/d1';
import HeroSection from '../components/HeroSection.astro';
import TrustSection from '../components/TrustSection.astro';
import FeaturedArticles from '../components/FeaturedArticles.astro';
import FeaturedMcpServers from '../components/FeaturedMcpServers.astro';
import FAQSection from '../components/FAQSection.astro';
import ServerGrid from '../components/ServerGrid';
import BaseLayout from '../layouts/BaseLayout.astro';
import { staticServers } from '../data/staticServers.js';

const FEATURED_IDS = [
  'playwright-browser-automation', 
  'mastra-docs', 
  'semiotic', 
  'specs-workflow-mcp',
  'jetski', 
  'mcp-operator', 
  'mindsdb-mcp', 
  '1panel', 
  'upstash-context7', 
  'github',
  'drawio-mcp',
  'cloudflare-mcp-official'
];

const db = (Astro.locals as any).runtime?.env?.DB as D1Database | undefined;

let initialServers: MCPServer[] = [];
let total = 0;
let featuredServers: MCPServer[] = [];

if (db) {
  try {
    const [firstPage, featured] = await Promise.all([
      getServersPage(db, { limit: 24 }),
      getFeaturedServers(db, FEATURED_IDS),
    ]);
    initialServers = firstPage.servers;
    total = firstPage.total;
    
    // Use staticServers as the primary source for featured servers to ensure they match our manual list
    const featuredMap = new Map(featured.map(s => [s.id, s]));
    featuredServers = FEATURED_IDS.map(id => {
      // Prioritize static data for featured targets
      const staticMatch = (staticServers as any[]).find(s => s.id === id);
      if (staticMatch) return staticMatch as MCPServer;
      
      // Fallback to database if not in static list
      return featuredMap.get(id) || null;
    }).filter(Boolean) as MCPServer[];
    
  } catch (error) {
    console.error('Error fetching servers from DB:', error);
    // Complete fallback if DB query fails entirely
    initialServers = (staticServers as any[]).slice(0, 24) as MCPServer[];
    total = staticServers.length;
    featuredServers = (staticServers as any[]).filter(s => FEATURED_IDS.includes(s.id)) as MCPServer[];
  }
} else {
  // Fallback for static builds or local dev without DB
  initialServers = (staticServers as any[]).slice(0, 24) as MCPServer[];
  total = staticServers.length;
  featuredServers = (staticServers as any[]).filter(s => FEATURED_IDS.includes(s.id)) as MCPServer[];
}
---

<BaseLayout
  title="My MCP Shelf"
  description="Your curated collection of 165+ premium Model Context Protocol servers for enhanced AI capabilities"
  canonical="https://www.mymcpshelf.com/"
>

<style is:global>
        :root {
            --bg-gradient-start: #f9f7f5;
            --bg-gradient-end: #f9f7f5;
            --text-primary: #333;
            --text-light: rgba(255, 255, 255, 0.9);
            --card-bg: rgba(255, 255, 255, 0.95);
            --card-text: #333;
            --card-shadow: rgba(0, 0, 0, 0.1);
            --header-bg: rgba(255, 255, 255, 0.1);
            --border-color: rgba(255, 255, 255, 0.2);
            --hero-bg: #0f172a;
            --hero-text: #ffffff;
            --hero-subtext: #cbd5e1;
            --cta-primary: #f59e0b;
            --cta-hover: #d97706;
        }

        html.dark-mode {
            --bg-gradient-start: #1a1a2e;
            --bg-gradient-end: #16213e;
            --text-primary: #e0e0e0;
            --text-light: rgba(255, 255, 255, 0.95);
            --card-bg: rgba(30, 30, 46, 0.95);
            --card-text: #e0e0e0;
            --card-shadow: rgba(0, 0, 0, 0.3);
            --header-bg: rgba(0, 0, 0, 0.2);
            --border-color: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Libre Franklin', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
            min-height: 100vh;
            color: var(--text-primary);
            transition: background 0.3s ease, color 0.3s ease;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .theme-toggle {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 12px var(--card-shadow);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .theme-toggle:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px var(--card-shadow);
        }

        .theme-toggle svg {
            width: 24px;
            height: 24px;
            fill: var(--card-text);
        }

        .header {
            text-align: center;
            padding: 3rem 1rem 2rem;
            background: var(--header-bg);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
        }

        .header h1 {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(45deg, #fff, #e0e7ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .header p {
            color: var(--text-light);
            font-size: 1.2rem;
            max-width: 600px;
            margin: 0 auto;
        }

        .search-section {
            padding: 2rem 1rem 3rem;
            max-width: 1200px;
            margin: 15px auto;
            overflow: visible;
            position: relative;
            z-index: 5;
            background: rgba(255, 255, 255, 0.95);
        }

        .search-section-heading {
            text-align: center;
            font-size: 2rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 2rem;
        }

        html.dark-mode .search-section-heading {
            color: #e0e0e0;
        }

        .search-bar {
            position: relative;
            max-width: 500px;
            margin: 0 auto 2rem;
        }

        .search-input {
            width: 100%;
            padding: 1rem 1rem 1rem 3rem;
            border: none;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.95);
            color: #333;
            backdrop-filter: blur(10px);
            font-size: 1rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
        }

        html.dark-mode .search-input {
            background: rgba(255, 255, 255, 0.95);
            color: #333;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .search-input::placeholder {
            color: #999;
        }

        .search-input:focus {
            outline: none;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
            transform: translateY(-2px);
        }

        .search-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #666;
        }

        .categories {
            display: flex;
            gap: 0.5rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 2rem;
            width: 100%;
            overflow: visible;
            min-height: 80px;
            padding: 1rem 0;
            position: relative;
            z-index: 10;
        }

        .category-tag {
            padding: 0.5rem 1rem;
            background: #f3f4f6;
            backdrop-filter: blur(10px);
            border: 1px solid #d1d5db;
            border-radius: 2rem;
            color: #374151;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            cursor: pointer;
            display: inline-block !important;
            visibility: visible !important;
            opacity: 1 !important;
            margin: 0.25rem 0;
            white-space: nowrap;
            position: relative;
            z-index: 1;
            min-width: fit-content;
            height: auto !important;
            width: auto !important;
            overflow: visible !important;
        }

        .category-tag:hover,
        .category-tag.active {
            background: #f59e0b;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(245, 158, 11, 0.3);
        }

        .category-tag {
            display: inline-block !important;
            visibility: visible !important;
            opacity: 1 !important;
            height: auto !important;
            width: auto !important;
            transform: none !important;
            clip: auto !important;
            clip-path: none !important;
            overflow: visible !important;
            position: static !important;
            left: auto !important;
            top: auto !important;
            right: auto !important;
            bottom: auto !important;
            margin: 0.25rem;
            padding: 0.5rem 1rem;
            background: #f3f4f6 !important;
            border: 1px solid #d1d5db !important;
            color: #374151 !important;
            font-size: 0.9rem !important;
            border-radius: 2rem !important;
            cursor: pointer !important;
            transition: all 0.3s ease !important;
            content-visibility: visible !important;
            contain: none !important;
        }

        .category-tag.active {
            background: #f59e0b !important;
            color: white !important;
            transform: translateY(-2px) !important;
            box-shadow: 0 4px 16px rgba(245, 158, 11, 0.3) !important;
            border-color: #f59e0b !important;
            font-weight: 600 !important;
        }

        .category-tag:not(.active) {
            background: #f3f4f6 !important;
            border-color: #d1d5db !important;
            color: #374151 !important;
        }

        .category-tag:hover:not(.active) {
            background: #fef3c7 !important;
            border-color: #f59e0b !important;
            color: #92400e !important;
            transform: translateY(-1px) !important;
        }

        .categories {
            display: flex !important;
            flex-wrap: wrap !important;
            justify-content: center !important;
            gap: 0.5rem !important;
            width: 100% !important;
            min-height: 100px !important;
            padding: 1rem 0 !important;
            overflow: visible !important;
            position: relative !important;
            z-index: 10 !important;
            align-items: center !important;
            align-content: center !important;
        }

        .search-section .categories,
        .search-section .category-tag,
        body .categories,
        body .category-tag,
        html .categories,
        html .category-tag,
        .search-section .category-tag:not(.active),
        body .category-tag:not(.active) {
            display: inline-block !important;
            visibility: visible !important;
            opacity: 1 !important;
            position: static !important;
            height: auto !important;
            width: auto !important;
            overflow: visible !important;
            flex-shrink: 0 !important;
        }

        .servers-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .server-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .server-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 64px rgba(0, 0, 0, 0.15);
        }

        .server-card-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .server-card-link:hover {
            text-decoration: none;
        }

        .server-header {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .icon-wrapper {
            position: relative;
            width: 48px;
            height: 48px;
            flex-shrink: 0;
        }

        .server-logo {
            width: 48px;
            height: 48px;
            border-radius: 0.75rem;
            object-fit: cover;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: 2px solid rgba(255, 255, 255, 0.1);
            display: block;
        }

        .server-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .server-title {
            flex: 1;
        }

        .server-title h3 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 0.25rem;
        }

        .server-author {
            color: #666;
            font-size: 0.9rem;
        }

        .server-description {
            color: #555;
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .server-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .meta-tag {
            background: rgba(102, 126, 234, 0.1);
            color: #667eea;
            padding: 0.25rem 0.5rem;
            border-radius: 0.5rem;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .repo-stats {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-top: 0.5rem;
            flex-wrap: wrap;
        }

        .repo-stat {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            font-size: 0.75rem;
            color: #666;
        }

        .repo-stat-fresh { color: #10b981; }
        .repo-stat-stale { color: #f59e0b; }
        .repo-stat-abandoned { color: #ef4444; }
        .repo-stat-loading { color: #999; font-style: italic; }

        .server-actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn {
            padding: 0.5rem 1rem;
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: hsl(var(--primary));
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(238, 123, 48, 0.3);
        }

        .btn-secondary {
            background: rgba(0, 0, 0, 0.05);
            color: #666;
            border: 1px solid rgba(0, 0, 0, 0.1);
        }

        .btn-secondary:hover {
            background: rgba(0, 0, 0, 0.1);
        }

        .stats-section {
            text-align: center;
            padding: 2rem 1rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .stat-item {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 1.5rem;
            border-radius: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: rgba(255, 255, 255, 0.8);
        }

        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }

        .skeleton-shimmer {
            background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 2.5rem;
            }

            .servers-grid {
                grid-template-columns: 1fr;
            }

            .categories {
                gap: 0.25rem;
            }

            .category-tag {
                font-size: 0.8rem;
                padding: 0.4rem 0.8rem;
            }
        }
    </style>

    <!-- Hero Section -->
    <HeroSection serverCount={total || 600} skillsCount={68} clientsCount={250} />

    <!-- Trust Section -->
    <TrustSection />

    <!-- Featured Articles -->
    <FeaturedArticles />

    <!-- Featured MCP Servers -->
    <FeaturedMcpServers servers={featuredServers} />

    <!-- Server Grid (search + categories + paginated cards) -->
    <ServerGrid client:load initialServers={initialServers} total={total} />

    <!-- FAQ Section -->
    <FAQSection />

</BaseLayout>

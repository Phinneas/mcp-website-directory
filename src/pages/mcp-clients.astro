---
export const prerender = true;
// MCP Clients Page
import clientsData from '../../clients.json';
import HeaderNewsletter from '../components/HeaderNewsletter.astro';
import { SearchIcon, ComputerIcon, CheckCircleIcon, ExternalLinkIcon, GithubIcon } from '../components/VintageIcon';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

// Get today's date for "Last Updated"
const lastUpdated = new Date().toLocaleDateString('en-US', { 
    month: 'long', 
    day: 'numeric', 
    year: 'numeric' 
});

// Heuristic for "Verified" - high profile ones or well known
const verifiedClients = [
    'VS Code', 'Cursor', 'Cline', 'Continue', 'Zed', 'Claude', 'Windsurf', 'Roo Code', 'Cherry Studio'
];

// Logo resolution helper
function getClientLogo(url: string | undefined | null) {
    if (!url) return null;
    const match = url.match(/github\.com\/([^\/]+)/);
    if (match) {
        return `https://github.com/${match[1]}.png?size=128`;
    }
    return null;
}

const processedClients = clientsData.map(client => ({
    ...client,
    isVerified: verifiedClients.includes(client.title) || (client.stars > 500),
    logoUrl: getClientLogo(client.url)
}));
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MCP Clients | My MCP Shelf</title>
    <meta name="description" content="Discover premium MCP client applications and integrations. Curated list of verified tools connecting to the Model Context Protocol.">
    <link rel="canonical" href="https://www.mymcpshelf.com/mcp-clients" />
    <meta name="google-site-verification" content="qmL-eYN3ygqiuLXVWHuWWko8vIBJj3hAYizdpo7dDug" />
    <meta name="msvalidate.01" content="8AA5A1EBF656D16B95B78BE654843905" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.png" type="image/png">
    <!-- Dark mode flash prevention - must run before styles -->
    <script>
        (function() {
            const theme = localStorage.getItem('theme');
            if (theme === 'dark') {
                document.documentElement.classList.add('dark-mode');
            }
        })();
    </script>

    <!-- Plausible Analytics -->
    <script defer data-domain="mymcpshelf.com" src="https://plausible-analytics-ce-production-7165.up.railway.app/js/script.js"></script>

    <style>
        :root {
            --bg-gradient-start: hsl(var(--background));
            --bg-gradient-end: hsl(var(--background));
            --text-primary: hsl(var(--foreground));
            --text-light: hsl(var(--foreground) / 0.9);
            --card-bg: hsla(var(--card), 1);
            --card-text: hsl(var(--card-foreground));
            --card-shadow: hsla(0, 0%, 0%, 0.05);
            --border-color: hsla(var(--border), 0.2);
            --accent-primary: hsl(var(--primary));
            --verified-color: #10b981;
        }

        body.dark-mode {
            --card-shadow: hsla(0, 0%, 0%, 0.3);
            --border-color: hsla(var(--border), 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Libre Franklin', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            background: var(--bg-gradient-start);
            color: var(--text-primary);
            transition: background 0.3s ease, color 0.3s ease;
            line-height: 1.5;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .theme-toggle {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 12px var(--card-shadow);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .theme-toggle:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px var(--card-shadow);
        }

        .theme-toggle svg {
            width: 24px;
            height: 24px;
            fill: var(--card-text);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }

        .hero-section {
            text-align: center;
            margin-bottom: 3rem;
            padding: 4rem 0 2rem;
            background: radial-gradient(circle at center, hsla(var(--primary), 0.05) 0%, transparent 70%);
            border-radius: 40px;
        }

        .hero-title {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 800;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--secondary)) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1rem;
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: hsl(var(--muted-foreground));
            max-width: 700px;
            margin: 0 auto 2.5rem;
        }

        .stats-bar {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            color: hsl(var(--foreground));
            display: block;
        }

        .stat-label {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: hsl(var(--muted-foreground));
        }

        .search-section {
            position: sticky;
            top: 5rem;
            z-index: 10;
            max-width: 800px;
            margin: 0 auto 4rem;
            padding: 0 1rem;
        }

        .search-wrapper {
            background: hsla(var(--card), 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 0.5rem;
            display: flex;
            align-items: center;
            box-shadow: 0 20px 40px var(--card-shadow);
        }

        .search-icon {
            padding: 0 1rem;
            color: hsl(var(--muted-foreground));
        }

        .search-input {
            flex: 1;
            border: none;
            outline: none;
            font-size: 1.1rem;
            padding: 0.75rem 0;
            background: transparent;
            color: hsl(var(--foreground));
        }

        .filter-tabs {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1.5rem;
            flex-wrap: wrap;
        }

        .filter-tab {
            padding: 0.5rem 1.25rem;
            border-radius: 100px;
            background: hsla(var(--card), 0.5);
            border: 1px solid var(--border-color);
            color: hsl(var(--muted-foreground));
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .filter-tab:hover {
            border-color: hsl(var(--primary));
            color: hsl(var(--primary));
        }

        .filter-tab.active {
            background: hsl(var(--primary));
            color: white;
            border-color: hsl(var(--primary));
            box-shadow: 0 4px 12px hsla(var(--primary), 0.3);
        }

        /* Clients Grid */
        .clients-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .client-card {
            background: var(--card-bg);
            border-radius: 24px;
            padding: 2rem;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 20px var(--card-shadow);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .client-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 30px var(--card-shadow);
            border-color: hsla(var(--primary), 0.3);
        }

        .client-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, transparent, hsla(var(--primary), 0.5), transparent);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .client-card:hover::after {
            opacity: 1;
        }

        .client-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
        }

        .client-info {
            display: flex;
            gap: 1.25rem;
        }

        .client-icon-box {
            width: 56px;
            height: 56px;
            background: hsla(var(--primary), 0.1);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: hsl(var(--primary));
            flex-shrink: 0;
        }

        .client-title-area h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: hsl(var(--foreground));
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .badge-verified {
            color: var(--verified-color);
            display: flex;
            align-items: center;
        }

        .client-tagline {
            font-size: 0.875rem;
            color: hsl(var(--muted-foreground));
            font-weight: 500;
        }

        .client-description {
            font-size: 1rem;
            color: hsl(var(--foreground) / 0.8);
            line-height: 1.6;
            margin-bottom: 2rem;
            flex-grow: 1;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .client-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-color);
        }

        .client-meta {
            display: flex;
            gap: 1rem;
        }

        .meta-stat {
            display: flex;
            align-items: center;
            gap: 0.375rem;
            font-size: 0.875rem;
            font-weight: 600;
            color: hsl(var(--muted-foreground));
        }

        .btn-visit {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.5rem;
            background: hsl(var(--foreground));
            color: hsl(var(--background));
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .btn-visit:hover {
            transform: scale(1.02);
            opacity: 0.9;
        }

        .page-footer {
            text-align: center;
            margin-top: 6rem;
            padding: 4rem 2rem;
            border-top: 1px solid var(--border-color);
            color: hsl(var(--muted-foreground));
        }

        .last-updated {
            font-weight: 600;
            font-size: 0.9rem;
            background: hsla(var(--primary), 0.1);
            color: hsl(var(--primary));
            padding: 0.5rem 1rem;
            border-radius: 100px;
            display: inline-block;
            margin-bottom: 1rem;
        }

        @media (max-width: 768px) {
            .container { padding: 1rem; }
            .clients-grid { grid-template-columns: 1fr; }
            .hero-section { padding: 3rem 1rem; }
            .search-section { top: 1rem; }
        }
    </style>
</head>
<body>
    <Navbar />
    
    <!-- Dark Mode Toggle -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
        <svg id="sunIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3" stroke="currentColor" stroke-width="2"/>
            <line x1="12" y1="21" x2="12" y2="23" stroke="currentColor" stroke-width="2"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke="currentColor" stroke-width="2"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke="currentColor" stroke-width="2"/>
            <line x1="1" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="2"/>
            <line x1="21" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="2"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke="currentColor" stroke-width="2"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke="currentColor" stroke-width="2"/>
        </svg>
        <svg id="moonIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="display: none;">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
    </button>

    <div class="container">
        <section class="hero-section">
            <h1 class="hero-title">MCP Client Directory</h1>
            <p class="hero-subtitle">The definitive list of applications and integrations connecting to the Model Context Protocol.</p>

            <div class="stats-bar">
                <div class="stat-item">
                    <span class="stat-value">{processedClients.length}</span>
                    <span class="stat-label">Clients</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">{verifiedClients.length}</span>
                    <span class="stat-label">Verified</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">100%</span>
                    <span class="stat-label">Open Source</span>
                </div>
            </div>
        </section>

        <div style="margin-bottom: 4rem; display: flex; justify-content: center;">
            <HeaderNewsletter />
        </div>

        <div class="search-section">
            <div class="search-wrapper">
                <span class="search-icon"><SearchIcon client:load size={24} /></span>
                <input type="text" class="search-input" placeholder="Search by name, description, or feature..." id="searchInput">
            </div>
            <div class="filter-tabs">
                <button class="filter-tab active" data-filter="all">All Clients</button>
                <button class="filter-tab" data-filter="verified">Verified Only</button>
                <button class="filter-tab" data-filter="github">GitHub Repos</button>
            </div>
        </div>

        <div class="clients-grid" id="clientsGrid">
            {processedClients.map((client) => (
                <div class="client-card" 
                     data-verified={client.isVerified ? "true" : "false"}
                     data-github={client.url.includes('github.com') ? "true" : "false"}>
                    <div class="client-header">
                        <div class="client-info">
                            <div class="client-icon-box" style="overflow: hidden;">
                                {client.logoUrl ? (
                                    <img 
                                        src={client.logoUrl} 
                                        alt="" 
                                        style="width: 100%; height: 100%; object-fit: cover;"
                                        onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                                    />
                                    <div style="display: none;"><ComputerIcon client:load size={32} /></div>
                                ) : (
                                    <ComputerIcon client:load size={32} />
                                )}
                            </div>
                            <div class="client-title-area">
                                <h3>
                                    {client.title}
                                    {client.isVerified && (
                                        <span class="badge-verified" title="Verified Quality">
                                            <CheckCircleIcon client:load size={20} />
                                        </span>
                                    )}
                                </h3>
                                <div class="client-tagline">MCP Client Integration</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="client-description">
                        {client.description || "A powerful integration for connecting AI models to external tools and data via the Model Context Protocol."}
                    </div>

                    <div class="client-footer">
                        <div class="client-meta">
                            {client.stars > 0 && (
                                <div class="meta-stat">
                                    <span style="color: #f59e0b">★</span> {client.stars}
                                </div>
                            )}
                            {client.url.includes('github.com') && (
                                <div class="meta-stat">
                                    <GithubIcon client:load size={16} />
                                    GitHub
                                </div>
                            )}
                        </div>
                        <a href={client.url} target="_blank" rel="noopener noreferrer" class="btn-visit">
                            View Project
                            <ExternalLinkIcon client:load size={16} />
                        </a>
                    </div>
                </div>
            ))}
        </div>

        <footer class="page-footer">
            <div class="last-updated">Last Validated: {lastUpdated}</div>
            <p>Spot an issue? Help us keep the directory clean by suggesting a fix on <a href="https://github.com/Phinneas/mcp-website-directory" style="color: inherit; font-weight: bold;">GitHub</a>.</p>
            <p style="margin-top: 1rem; font-size: 0.8rem;">Note: Listing does not constitute endorsement. Always verify tools before installing.</p>
        </footer>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput') as HTMLInputElement;
            const clientsGrid = document.getElementById('clientsGrid');
            const filterTabs = document.querySelectorAll('.filter-tab');
            let currentFilter = 'all';

            function updateDisplay() {
                if (!searchInput || !clientsGrid) return;
                const searchTerm = searchInput.value.toLowerCase();
                const cards = clientsGrid.querySelectorAll('.client-card');
                let visibleCount = 0;

                cards.forEach(c => {
                    const card = c as HTMLElement;
                    const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
                    const description = card.querySelector('.client-description')?.textContent?.toLowerCase() || '';
                    const isVerified = card.getAttribute('data-verified') === 'true';
                    const isGithub = card.getAttribute('data-github') === 'true';

                    const matchesSearch = title.includes(searchTerm) || description.includes(searchTerm);
                    const matchesFilter = 
                        currentFilter === 'all' || 
                        (currentFilter === 'verified' && isVerified) ||
                        (currentFilter === 'github' && isGithub);

                    if (matchesSearch && matchesFilter) {
                        card.style.display = 'flex';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            searchInput?.addEventListener('input', updateDisplay);

            filterTabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    filterTabs.forEach(t => t.classList.remove('active'));
                    tab.classList.add('active');
                    currentFilter = tab.getAttribute('data-filter') || 'all';
                    updateDisplay();
                });
            });

            // Dark mode toggle
            const themeToggle = document.getElementById('themeToggle');
            const sunIcon = document.getElementById('sunIcon');
            const moonIcon = document.getElementById('moonIcon');
            const html = document.documentElement;

            themeToggle?.addEventListener('click', () => {
                const isDark = html.classList.toggle('dark-mode');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                if (sunIcon) (sunIcon as HTMLElement).style.display = isDark ? 'none' : 'block';
                if (moonIcon) (moonIcon as HTMLElement).style.display = isDark ? 'block' : 'none';
            });
            
            // Initial theme setup
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'dark' && sunIcon && moonIcon) {
                (sunIcon as HTMLElement).style.display = 'none';
                (moonIcon as HTMLElement).style.display = 'block';
            }
        });
    </script>
</body>
</html>

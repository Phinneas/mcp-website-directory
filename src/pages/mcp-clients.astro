---
export const prerender = true;
// MCP Clients Page - Matching Skills Directory Look
import clientsData from '../../clients.json';
import HeaderNewsletter from '../components/HeaderNewsletter.astro';
import { SearchIcon, ComputerIcon, CheckCircleIcon, ExternalLinkIcon, GithubIcon } from '../components/VintageIcon';
import BaseLayout from '../layouts/BaseLayout.astro';

// Get today's date for "Last Updated"
const lastUpdated = new Date().toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
});

// Heuristic for "Verified" - high profile ones or well known
const verifiedClients = [
    'VS Code', 'Cursor', 'Cline', 'Continue', 'Zed', 'Claude', 'Windsurf', 'Roo Code', 'Cherry Studio'
];

// Logo resolution helper
function getClientLogo(url: string | undefined | null) {
    if (!url) return null;
    const match = url.match(/github\.com\/([^\/]+)/);
    if (match) {
        return `https://github.com/${match[1]}.png?size=128`;
    }
    return null;
}

const processedClients = clientsData.map(client => ({
    ...client,
    isVerified: verifiedClients.includes(client.title) || (client.stars > 500),
    logoUrl: getClientLogo(client.url)
}));

const categories = ['All', 'Verified', 'GitHub', 'Desktop', 'CLI'];
---

<BaseLayout
    title="MCP Clients Directory | My MCP Shelf"
    description="Browse and discover MCP client applications — extend your AI assistants with tools for connecting to the Model Context Protocol."
    canonical="https://www.mymcpshelf.com/mcp-clients"
>
    <div class="page-container">
        <!-- Hero Section -->
        <section class="hero-section">
            <h1 class="hero-title">MCP Clients Directory</h1>
            <p class="hero-subtitle">
                The most comprehensive directory of applications and integrations connecting to the Model Context Protocol.
            </p>

            <div class="stats-bar">
                <div class="stat-item">
                    <div class="stat-value">{processedClients.length}</div>
                    <div class="stat-label">Clients</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">{verifiedClients.length}</div>
                    <div class="stat-label">Verified</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">Daily</div>
                    <div class="stat-label">Updates</div>
                </div>
            </div>
        </section>

        <!-- Newsletter -->
        <div style="margin-top: 1.5rem; display: flex; justify-content: center;">
            <HeaderNewsletter />
        </div>

        <!-- Submit CTA -->
        <div class="submit-cta">
            <a href="https://github.com/Phinneas/mcp-website-directory/issues/new" class="submit-btn">
                🚀 Submit an MCP Client
            </a>
        </div>

        <!-- Search -->
        <div class="search-section">
            <div class="search-input-wrapper">
                <input
                    type="text"
                    id="searchInput"
                    class="search-input"
                    placeholder="Search MCP clients by name or feature..."
                />
            </div>
        </div>

        <!-- Category Filters -->
        <div class="category-filters" id="categoryFilters">
            {categories.map(category => (
                <div
                    class={`category-pill ${category === 'All' ? 'active' : ''}`}
                    data-category={category}
                >
                    {category}
                </div>
            ))}
        </div>

        <!-- Clients Grid -->
        <section class="clients-section">
            <div class="clients-grid" id="clientsGrid">
                {processedClients.map(client => (
                    <div class="client-card"
                         data-verified={client.isVerified ? "true" : "false"}
                         data-github={client.url.includes('github.com') ? "true" : "false"}>
                        <div class="client-header">
                            <div class="client-logo-box">
                                {client.logoUrl ? (
                                    <img
                                        src={client.logoUrl}
                                        alt=""
                                        style="width: 100%; height: 100%; object-fit: cover;"
                                        onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                                    />
                                    <div style="display: none;"><ComputerIcon client:load size={32} /></div>
                                ) : (
                                    <ComputerIcon client:load size={24} />
                                )}
                            </div>
                            <div class="client-title-area">
                                <h3 class="client-title">
                                    {client.title}
                                    {client.isVerified && (
                                        <span class="client-verified" title="Verified Quality">
                                            <CheckCircleIcon client:load size={18} />
                                        </span>
                                    )}
                                </h3>
                                <div style="font-size: 0.8rem; color: #94a3b8;">
                                    {client.url.includes('github.com') ? 'Open Source' : 'Native App'}
                                </div>
                            </div>
                        </div>
                        <p class="client-description">
                            {client.description || "A powerful integration for connecting AI models to external tools and data via the Model Context Protocol."}
                        </p>
                        <div class="client-footer">
                            <div class="client-stats">
                                {client.stars > 0 && <span>★ {client.stars}</span>}
                                {client.url.includes('github.com') && <GithubIcon client:load size={16} />}
                            </div>
                            <a href={client.url} target="_blank" rel="noopener noreferrer" class="client-btn">
                                View <ExternalLinkIcon client:load size={14} />
                            </a>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <div class="last-updated">
            <p>Last Validated: {lastUpdated}</p>
            <p style="margin-top: 0.5rem; opacity: 0.7;">
                Found an error? <a href="https://github.com/Phinneas/mcp-website-directory" style="color: inherit;">Edit on GitHub</a>
            </p>
        </div>
    </div>

    <script>
        const searchInput = document.getElementById('searchInput') as HTMLInputElement;
        const clientsGrid = document.getElementById('clientsGrid');
        const categoryFilters = document.getElementById('categoryFilters');

        function updateDisplay() {
            if (!searchInput || !clientsGrid) return;
            const searchTerm = searchInput.value.toLowerCase();
            const selectedCategory = document.querySelector('.category-pill.active')?.getAttribute('data-category') || 'All';
            const cards = clientsGrid.querySelectorAll('.client-card');

            cards.forEach(c => {
                const card = c as HTMLElement;
                const title = card.querySelector('.client-title')?.textContent?.toLowerCase() || '';
                const description = card.querySelector('.client-description')?.textContent?.toLowerCase() || '';
                const isVerified = card.getAttribute('data-verified') === 'true';
                const isGithub = card.getAttribute('data-github') === 'true';

                const matchesSearch = title.includes(searchTerm) || description.includes(searchTerm);

                let matchesCategory = true;
                if (selectedCategory === 'Verified') matchesCategory = isVerified;
                else if (selectedCategory === 'GitHub') matchesCategory = isGithub;
                else if (selectedCategory === 'All') matchesCategory = true;
                // Add more category filters as needed

                if (matchesSearch && matchesCategory) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        searchInput?.addEventListener('input', updateDisplay);

        categoryFilters?.addEventListener('click', (e) => {
            const pill = (e.target as HTMLElement).closest('.category-pill');
            if (!pill) return;

            document.querySelectorAll('.category-pill').forEach(p => p.classList.remove('active'));
            pill.classList.add('active');
            updateDisplay();
        });
    </script>
</BaseLayout>

<style>
    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
    }

    .hero-section {
        text-align: center;
        margin-bottom: 2rem;
        padding: 2rem 0;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, #f59e0b 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        font-size: 1.2rem;
        color: #94a3b8;
        max-width: 600px;
        margin: 0 auto 2rem;
    }

    .stats-bar {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 1rem;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #f59e0b;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #94a3b8;
    }

    .search-section {
        margin-bottom: 2rem;
    }

    .search-input-wrapper {
        position: relative;
        max-width: 600px;
        margin: 0 auto;
    }

    .search-input {
        width: 100%;
        padding: 1rem 1.5rem;
        border: 2px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        font-size: 1rem;
        outline: none;
        transition: all 0.3s ease;
        background: rgba(255,255,255,0.04);
        color: #f1f5f9;
    }

    .search-input:focus {
        border-color: #f59e0b;
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
    }

    .category-filters {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
        justify-content: center;
    }

    .category-pill {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04);
        color: #94a3b8;
    }

    .category-pill:hover, .category-pill.active {
        background: #f59e0b;
        color: white;
        border-color: #f59e0b;
    }

    .clients-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .client-card {
        background: rgba(255,255,255,0.04);
        border-radius: 12px;
        padding: 1.5rem;
        border: 1px solid rgba(255,255,255,0.1);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .client-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        border-color: #f59e0b;
    }

    .client-header {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1rem;
    }

    .client-logo-box {
        width: 48px;
        height: 48px;
        background: rgba(245, 158, 11, 0.1);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

    .client-title-area {
        flex: 1;
    }

    .client-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #f1f5f9;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .client-verified {
        color: #10b981;
        display: flex;
    }

    .client-description {
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .client-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.1);
    }

    .client-stats {
        display: flex;
        gap: 0.75rem;
        font-size: 0.85rem;
        color: #94a3b8;
    }

    .client-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        background: #f59e0b;
        color: white;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .client-btn:hover {
        opacity: 0.9;
    }

    .submit-cta {
        text-align: center;
        margin-bottom: 2rem;
    }

    .submit-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #f59e0b;
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    }

    .last-updated {
        text-align: center;
        font-size: 0.85rem;
        color: #94a3b8;
        margin-top: 4rem;
        padding: 2rem;
        border-top: 1px solid rgba(255,255,255,0.1);
    }

    @media (max-width: 768px) {
        .page-container { padding: 1rem; }
        .hero-title { font-size: 2rem; }
        .clients-grid { grid-template-columns: 1fr; }
    }
</style>

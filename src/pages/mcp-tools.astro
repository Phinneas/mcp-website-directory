---
export const prerender = true;
/**
 * MCP Tools Page
 * Unified page for Config Generator, Stack Builder, and Compatibility Matrix
 */
import { staticServers as importedStaticServers } from '../data/staticServers.js';
import MCPConfigGenerator from '../components/MCPConfigGenerator';
import StackBuilder from '../components/StackBuilder';
import CompatibilityMatrix from '../components/CompatibilityMatrix';
import BaseLayout from '../layouts/BaseLayout.astro';

const staticServers = importedStaticServers;
---

<BaseLayout
  title="MCP Tools Suite | MyMCPShelf"
  description="MCP configuration tools: Config Generator, Docker Stack Builder, and Compatibility Matrix"
  canonical="https://www.mymcpshelf.com/mcp-tools"
>
  <div class="page-container">
    <!-- Hero -->
    <div class="hero">
      <h1>MCP Tools Suite</h1>
      <p>
        Three powerful tools to configure, deploy, and verify your MCP server setup.
        Generate configs, build Docker stacks, and check compatibility in seconds.
      </p>
    </div>

    <!-- Feature Overview -->
    <div class="feature-overview">
      <div class="feature-card">
        <h3>⚙️ Config Generator</h3>
        <p>One-click configuration for Claude Desktop, Cursor, Cline, and more.</p>
        <ul>
          <li>5+ MCP clients supported</li>
          <li>Copy-paste ready JSON</li>
          <li>Auto-generated env vars</li>
        </ul>
      </div>

      <div class="feature-card">
        <h3>🐳 Stack Builder</h3>
        <p>Multi-select servers and export a ready-to-run docker-compose.yml.</p>
        <ul>
          <li>20+ Docker images mapped</li>
          <li>Auto-generated .env file</li>
          <li>One-click download</li>
        </ul>
      </div>

      <div class="feature-card">
        <h3>📊 Compatibility Matrix</h3>
        <p>Visual grid showing which servers work with which clients.</p>
        <ul>
          <li>Client × Server matrix</li>
          <li>Transport compatibility</li>
          <li>Crowdsourced data</li>
        </ul>
      </div>
    </div>

    <!-- Tool Tabs -->
    <div class="tool-tabs">
      <button class="tool-tab active" data-tab="config-generator">
        <span class="tool-tab-icon">⚙️</span>
        <span>Config Generator</span>
      </button>
      <button class="tool-tab" data-tab="stack-builder">
        <span class="tool-tab-icon">🐳</span>
        <span>Stack Builder</span>
      </button>
      <button class="tool-tab" data-tab="compatibility-matrix">
        <span class="tool-tab-icon">📊</span>
        <span>Compatibility Matrix</span>
      </button>
    </div>

    <!-- Tool Content -->
    <div id="config-generator" class="tool-tab-content active">
      <MCPConfigGenerator
        client:load
        servers={staticServers}
      />
    </div>

    <div id="stack-builder" class="tool-tab-content">
      <StackBuilder
        client:load
        servers={staticServers}
      />
    </div>

    <div id="compatibility-matrix" class="tool-tab-content">
      <CompatibilityMatrix
        client:load
        servers={staticServers}
      />
    </div>

    <!-- Footer -->
    <footer class="page-footer">
      <p>Built with ❤️ for the MCP community. All tools run client-side for instant results.</p>
    </footer>
  </div>

  <script>
    // Tab switching functionality
    document.querySelectorAll('.tool-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.tool-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tool-tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        const targetId = tab.getAttribute('data-tab');
        document.getElementById(targetId)?.classList.add('active');
      });
    });
  </script>
</BaseLayout>

<style>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    padding: 3rem 0;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #f59e0b 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.125rem;
    color: #94a3b8;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .tool-tabs {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .tool-tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    color: #94a3b8;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    flex: 1;
    min-width: 200px;
    justify-content: center;
  }

  .tool-tab:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: #f59e0b;
  }

  .tool-tab.active {
    background: rgba(245, 158, 11, 0.1);
    border-color: #f59e0b;
    color: #f59e0b;
  }

  .tool-tab-icon {
    font-size: 1.5rem;
  }

  .tool-tab-content {
    display: none;
  }

  .tool-tab-content.active {
    display: block;
  }

  .feature-overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    border-color: #f59e0b;
    transform: translateY(-4px);
  }

  .feature-card h3 {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: #f1f5f9;
  }

  .feature-card p {
    color: #94a3b8;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .feature-card ul {
    list-style: none;
    padding: 0;
  }

  .feature-card li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0;
    font-size: 0.9rem;
    color: #94a3b8;
  }

  .feature-card li::before {
    content: '✓';
    color: #10b981;
    font-weight: 600;
  }

  .page-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    color: #64748b;
    font-size: 0.875rem;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #94a3b8;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s ease;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-links a:hover {
    color: #f59e0b;
    border-color: #f59e0b;
  }

  @media (max-width: 768px) {
    .page-container { padding: 1rem; }
    .hero h1 { font-size: 2rem; }
    .tool-tabs { flex-direction: column; }
    .tool-tab { min-width: auto; }
  }
</style>

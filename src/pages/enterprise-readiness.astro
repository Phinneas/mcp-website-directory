---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Enterprise Readiness | MCP Directory';
const pageDescription = 'Compare MCP server deployment options and find the best solution for your enterprise infrastructure needs. Local, cloud-native, self-hosted, and SaaS options.';
const canonicalUrl = 'https://www.mymcpshelf.com/enterprise-readiness';

const deploymentOptions = [
  {
    key: 'local_stdio',
    name: 'Local & CLI',
    icon: '💻',
    badge: 'Best for Development',
    badgeClass: 'bg-blue-100 text-blue-800',
    description: 'stdio-based local tools perfect for development and testing',
    features: ['No internet required', 'Direct process communication', 'Easy debugging', 'Works offline'],
    requirements: ['Local runtime (Node.js/Python)', 'CLI access'],
    bestFor: 'Developers, testing, CI/CD',
    scalability: 'Single user',
    security: 'Full local control',
    sla: 'N/A',
    href: '/local-stdio'
  },
  {
    key: 'cloud_native',
    name: 'Cloud-Native',
    icon: '☁️',
    badge: 'Most Flexible',
    badgeClass: 'bg-purple-100 text-purple-800',
    description: 'SSE/WebSocket servers designed for cloud scalability',
    features: ['Real-time communication', 'HTTP-based transport', 'Auto-scaling', 'Remote team friendly'],
    requirements: ['Cloud provider account', 'SSL certificate'],
    bestFor: 'Growing teams, SaaS, remote work',
    scalability: 'High',
    security: 'Cloud provider security',
    sla: 'Up to 99.9%',
    href: '/cloud-native'
  },
  {
    key: 'self_hosted',
    name: 'Self-Hosted/VPC',
    icon: '🏢',
    badge: 'Enterprise Control',
    badgeClass: 'bg-green-100 text-green-800',
    description: 'Deploy in your own VPC or data center with full control',
    features: ['Complete data control', 'VPC deployment', 'Custom compliance', 'No vendor lock-in'],
    requirements: ['Server infrastructure', 'Docker/Kubernetes', 'Network admin skills'],
    bestFor: 'Enterprise compliance, regulated industries',
    scalability: 'Medium to High',
    security: 'Custom enterprise security',
    sla: 'Custom SLA',
    href: '/self-hosted'
  },
  {
    key: 'enterprise_saas',
    name: 'Enterprise SaaS',
    icon: '🔐',
    badge: 'Fully Managed',
    badgeClass: 'bg-orange-100 text-orange-800',
    description: 'Production-ready managed services with enterprise features',
    features: ['SSO/SAML authentication', 'Enterprise audit logs', 'SOC 2 Type II', 'Dedicated support'],
    requirements: ['Enterprise contract', 'SSO integration', 'Security review'],
    bestFor: 'Mission-critical apps, large scale',
    scalability: 'Unlimited',
    security: 'Enterprise-grade with certifications',
    sla: '99.9%+ guaranteed',
    href: '/enterprise-saas',
    cta: 'Contact Sales'
  }
];

const comparisonMatrix = [
  { feature: 'Communication Protocol', local_stdio: 'stdio', cloud_native: 'SSE/WebSocket', self_hosted: 'stdio/SSE', enterprise_saas: 'SSE/WebSocket' },
  { feature: 'Internet Required', local_stdio: false, cloud_native: true, self_hosted: false, enterprise_saas: true },
  { feature: 'Scalability', local_stdio: 'Single user', cloud_native: 'High', self_hosted: 'Medium-High', enterprise_saas: 'Unlimited' },
  { feature: 'Data Control', local_stdio: 'Full local', cloud_native: 'Cloud provider', self_hosted: 'Complete', enterprise_saas: 'Vendor managed' },
  { feature: 'Setup Complexity', local_stdio: 'Low', cloud_native: 'Medium', self_hosted: 'High', enterprise_saas: 'Low (managed)' },
  { feature: 'Maintenance', local_stdio: 'User', cloud_native: 'Cloud vendor', self_hosted: 'Your team', enterprise_saas: 'Vendor' },
  { feature: 'SSO Support', local_stdio: false, cloud_native: 'Optional', self_hosted: 'Configurable', enterprise_saas: true },
  { feature: 'Audit Logs', local_stdio: 'Limited', cloud_native: 'Cloud provider', self_hosted: 'Full', enterprise_saas: 'Enterprise' },
  { feature: 'SLA', local_stdio: 'N/A', cloud_native: 'Up to 99.9%', self_hosted: 'Custom', enterprise_saas: '99.9%+ guaranteed' },
  { feature: 'Typical Cost', local_stdio: 'Free (self-run)', cloud_native: 'Usage-based', self_hosted: 'Infrastructure + ops', enterprise_saas: 'Contract-based' }
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": canonicalUrl,
  "mainEntity": {
    "@type": "ItemList",
    "name": "MCP Server Deployment Options",
    "itemListElement": deploymentOptions.map((option, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": option.name,
      "description": option.description
    }))
  }
};
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    canonical={canonicalUrl}
    structuredData={structuredData}
>
    <div class="page-wrapper">
        <section class="hero-section">
            <div class="hero-content">
                <h1 class="page-title">Choose Your Deployment Strategy</h1>
                <p class="page-subtitle">Compare MCP server deployment options and find the perfect fit for your infrastructure, compliance, and scalability requirements.</p>
            </div>
        </section>

        <main class="page-container">
            <!-- Deployment Options Grid -->
            <section class="section">
                <div class="deployment-grid">
                    {deploymentOptions.map(option => (
                        <a href={option.href} class="deployment-card">
                            <div class="card-header">
                                <span class="card-icon">{option.icon}</span>
                                <div class="card-title-group">
                                    <h3 class="card-title">{option.name}</h3>
                                    <p class="card-subtitle">{option.subtitle || 'MCP Server Deployment'}</p>
                                </div>
                            </div>

                            <div class:list={['card-badge', option.badgeClass]}>{option.badge}</div>

                            <p class="card-description">{option.description}</p>

                            <ul class="card-features">
                                {option.features.slice(0, 4).map(feature => (
                                    <li>{feature}</li>
                                ))}
                            </ul>

                            <div class="card-footer">
                                <div class="btn btn-primary">
                                    {option.cta || `Explore ${option.name}`} →
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </section>

            <!-- Detailed Comparison Table -->
            <section class="section">
                <h2 class="section-title">Detailed Feature Comparison</h2>
                <p class="section-description">
                    Compare all deployment options side-by-side to make the best decision for your infrastructure needs.
                </p>

                <div class="comparison-table">
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Feature</th>
                                    <th>💻 Local & CLI</th>
                                    <th>☁️ Cloud-Native</th>
                                    <th>🏢 Self-Hosted/VPC</th>
                                    <th>🔐 Enterprise SaaS</th>
                                </tr>
                            </thead>
                            <tbody>
                                {comparisonMatrix.map(row => (
                                    <tr>
                                        <td>{row.feature}</td>
                                        <td>
                                            {typeof row.local_stdio === 'boolean'
                                                ? (row.local_stdio ? <span class="check-icon">✓</span> : <span class="cross-icon">✗</span>)
                                                : row.local_stdio}
                                        </td>
                                        <td>
                                            {typeof row.cloud_native === 'boolean'
                                                ? (row.cloud_native ? <span class="check-icon">✓</span> : <span class="cross-icon">✗</span>)
                                                : row.cloud_native}
                                        </td>
                                        <td>
                                            {typeof row.self_hosted === 'boolean'
                                                ? (row.self_hosted ? <span class="check-icon">✓</span> : <span class="cross-icon">✗</span>)
                                                : row.self_hosted}
                                        </td>
                                        <td>
                                            {typeof row.enterprise_saas === 'boolean'
                                                ? (row.enterprise_saas ? <span class="check-icon">✓</span> : <span class="cross-icon">✗</span>)
                                                : row.enterprise_saas}
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- CTA Section -->
            <section class="cta-section">
                <h2 class="cta-title">Ready to Deploy?</h2>
                <p class="cta-description">
                    Choose your deployment strategy and start exploring MCP servers designed for your infrastructure.
                </p>
                <div class="cta-buttons">
                    <a href="/" class="btn-white">
                        Browse All Servers
                    </a>
                    <a href="/submit-server" class="btn-outline-white">
                        Submit New Server
                    </a>
                </div>
            </section>

            <!-- FAQ Section -->
            <section class="section">
                <h2 class="section-title">Common Questions</h2>
                <div class="faq-grid">
                    <div class="faq-item">
                        <h3>Which deployment is best for a small team?</h3>
                        <p>For small teams, <strong>Local & CLI</strong> or <strong>Cloud-Native</strong> are typically best. Local is great for development, while Cloud-Native offers scalability as you grow.</p>
                    </div>

                    <div class="faq-item">
                        <h3>Do I need enterprise SaaS for compliance?</h3>
                        <p>If you need SOC 2, HIPAA, or other certifications without managing infrastructure yourself, Enterprise SaaS is the fastest path to compliance.</p>
                    </div>

                    <div class="faq-item">
                        <h3>Can I switch deployment types later?</h3>
                        <p>Many MCP servers support multiple deployment types. Start with Local development, then deploy to Cloud or Self-Hosted production environments using the same server.</p>
                    </div>
                </div>
            </section>
        </main>
    </div>
</BaseLayout>

<style>
    .page-wrapper {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .hero-section {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
        padding: 4rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        text-align: center;
    }

    .hero-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .page-title {
        font-size: 3rem;
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 1rem;
        background: linear-gradient(135deg, #ffffff 0%, #60a5fa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .page-subtitle {
        font-size: 1.25rem;
        color: #94a3b8;
        margin-bottom: 2rem;
        font-weight: 400;
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        flex: 1;
    }

    .section {
        margin: 3rem 0;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 1rem;
        text-align: center;
        color: #f1f5f9;
    }

    .section-description {
        font-size: 1.1rem;
        color: #94a3b8;
        text-align: center;
        margin-bottom: 3rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .deployment-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .deployment-card {
        background: #1e293b;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
    }

    .deployment-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        border-color: #f59e0b;
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .card-icon {
        font-size: 2rem;
        line-height: 1;
    }

    .card-title-group {
        flex: 1;
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #f1f5f9;
    }

    .card-subtitle {
        font-size: 0.875rem;
        color: #94a3b8;
    }

    .card-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
        background: rgba(255,255,255,0.1);
        color: #f1f5f9;
    }

    .card-description {
        color: #94a3b8;
        margin-bottom: 1.5rem;
        flex: 1;
    }

    .card-features {
        list-style: none;
        margin-bottom: 1.5rem;
    }

    .card-features li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: #94a3b8;
        margin-bottom: 0.5rem;
    }

    .card-features li::before {
        content: '✓';
        color: #10b981;
        font-weight: bold;
        font-size: 0.75rem;
    }

    .card-footer {
        margin-top: auto;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.15s ease;
        font-size: 0.875rem;
        width: 100%;
    }

    .btn-primary {
        background: linear-gradient(135deg, #f59e0b 0%, #3b82f6 100%);
        color: white;
        border: none;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        color: #f1f5f9;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: #f59e0b;
    }

    .comparison-table {
        background: #1e293b;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 3rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .table-wrapper {
        overflow-x: auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

    thead {
        background: rgba(255, 255, 255, 0.05);
    }

    th {
        padding: 1rem;
        text-align: left;
        font-weight: 600;
        color: #f1f5f9;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    th:first-child {
        position: sticky;
        left: 0;
        background: rgba(255, 255, 255, 0.05);
        z-index: 1;
    }

    td {
        padding: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        color: #94a3b8;
    }

    td:first-child {
        position: sticky;
        left: 0;
        background: #1e293b;
        font-weight: 500;
        color: #f1f5f9;
        z-index: 1;
    }

    tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .check-icon {
        color: #10b981;
        font-weight: bold;
    }

    .cross-icon {
        color: #ef4444;
    }

    .info-icon {
        color: #f59e0b;
    }

    .cta-section {
        background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
        border-radius: 12px;
        padding: 3rem;
        text-align: center;
        color: white;
        margin: 3rem 0;
    }

    .cta-title {
        font-size: 2rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .cta-description {
        font-size: 1.1rem;
        margin-bottom: 2rem;
        opacity: 0.9;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-white {
        background: white;
        color: #1e40af;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.15s ease;
    }

    .btn-white:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 255, 255, 0.25);
    }

    .btn-outline-white {
        background: transparent;
        color: white;
        border: 2px solid white;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.15s ease;
    }

    .btn-outline-white:hover {
        background: white;
        color: #1e40af;
    }

    .faq-grid {
        display: grid;
        gap: 1.5rem;
    }

    .faq-item {
        background: #1e293b;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .faq-item h3 {
        font-size: 1.1rem;
        font-weight: 600;
        color: #f1f5f9;
        margin-bottom: 0.75rem;
    }

    .faq-item p {
        color: #94a3b8;
        line-height: 1.7;
    }

    .faq-item strong {
        color: #f1f5f9;
    }

    @media (max-width: 768px) {
        .page-title {
            font-size: 2rem;
        }

        .deployment-grid {
            grid-template-columns: 1fr;
        }

        .table-wrapper {
            font-size: 0.75rem;
        }

        th, td {
            padding: 0.75rem 0.5rem;
        }

        .cta-buttons {
            flex-direction: column;
        }

        .btn-white, .btn-outline-white {
            width: 100%;
        }
    }
</style>

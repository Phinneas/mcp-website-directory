---
import { getCategoryDisplayName } from '../utils/serverData.js';

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};

// Check if we're on a deployment category page
const isDeploymentPage = ['/local-stdio', '/cloud-native', '/self-hosted', '/enterprise-saas'].some(path => isActive(path));
const isHome = pathname === '/' || isDeploymentPage;

// Deployment navigation items
const deploymentNavItems = [
  {
    href: '/local-stdio',
    label: 'Local & CLI',
    icon: '💻',
    description: 'stdio-based local tools',
    badge: 'Local',
    active: isActive('/local-stdio')
  },
  {
    href: '/cloud-native',
    label: 'Cloud-Native',
    icon: '☁️',
    description: 'SSE/WebSocket services',
    badge: 'Cloud',
    active: isActive('/cloud-native'),
    highlight: true
  },
  {
    href: '/self-hosted',
    label: 'Self-Hosted',
    icon: '🏢',
    description: 'On-premise/VPC deployment',
    badge: 'VPC',
    active: isActive('/self-hosted')
  },
  {
    href: '/enterprise-saas',
    label: 'Enterprise',
    icon: '🔐',
    description: 'Secure managed SaaS',
    badge: 'Enterprise',
    active: isActive('/enterprise-saas'),
    enterprise: true
  }
];

// Functional category items (existing categories)
const functionalCategories = [
  { href: '/category/databases', label: 'Databases', icon: '🗄️' },
  { href: '/category/cloud', label: 'Cloud & Infrastructure', icon: '☁️' },
  { href: '/category/ai-ml', label: 'AI / Machine Learning', icon: '🤖' },
  { href: '/category/development', label: 'Development Tools', icon: '🛠️' },
  { href: '/category/productivity', label: 'Productivity', icon: '📊' },
  { href: '/category/communication', label: 'Communication', icon: '💬' },
  { href: '/category/security', label: 'Security', icon: '🔒' },
  { href: '/category/all', label: 'View All →', icon: '→' }
];

// Utility nav items
const utilityNavItems = [
  { href: '/mcp-tools', label: 'MCP Tools', icon: '🧰' },
  { href: '/mcp-config-generator', label: 'Config Generator', icon: '⚙️' },
  { href: '/blog', label: 'Blog', icon: '📝' },
  { href: '/faq', label: 'FAQ', icon: '❓' },
  { href: '/submit-server', label: 'Submit Server', icon: '📤' },
  { href: '/agent-skills', label: 'Agent Skills', icon: '🤖' },
  { href: '/cursor-skills', label: 'Cursor Skills', icon: '✏️' },
  { href: '/mcp-clients', label: 'MCP Clients', icon: '💻' },
];
---
<nav class="site-navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-logo">
      <span class="logo-text">My MCP Shelf</span>
      <span class="navbar-subtitle">Deployment-Ready MCP Servers</span>
    </a>
    
    <div class="navbar-links">
      <!-- Primary: Deployment Categories -->
      <div class="nav-section">
        <span class="nav-section-label">Deploy By Target</span>
        <div class="nav-item-wrapper">
          {deploymentNavItems.map(item => (
            <a href={item.href} class:list={['nav-link', 'nav-link-primary', { active: item.active, 'nav-highlight': item.highlight, 'nav-enterprise': item.enterprise }]} title={item.description}>
              <span class="nav-icon">{item.icon}</span>
              <span class="nav-label">{item.label}</span>
              {item.badge && <span class="nav-badge">{item.badge}</span>}
            </a>
          ))}
        </div>
      </div>

      <!-- Secondary: Functional Categories -->
      <div class="nav-section">
        <span class="nav-section-label">By Function</span>
        <div class="nav-dropdown">
          <button class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
            <span>Categories</span>
            <span class="dropdown-arrow">▼</span>
          </button>
          <div class="nav-dropdown-menu">
            {functionalCategories.map(cat => (
              <a href={cat.href} class="nav-dropdown-item">
                <span class="nav-icon">{cat.icon}</span>
                <span>{cat.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Tertiary: Resources -->
      <div class="nav-section">
        <span class="nav-section-label">Resources</span>
        <div class="nav-dropdown">
          <button class="nav-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
            <span>Resources</span>
            <span class="dropdown-arrow">▼</span>
          </button>
          <div class="nav-dropdown-menu">
            {utilityNavItems.map(item => (
              <a href={item.href} class:list={['nav-dropdown-item', { active: isActive(item.href) }]}>
                <span class="nav-icon">{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Enterprise CTA -->
      <a href="/enterprise-readiness" class="enterprise-cta">
        <span class="enterprise-icon">🏢</span>
        <span>Enterprise</span>
      </a>
    </div>
  </div>
</nav>

<style is:global>
  .site-navbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: #0f172a;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .navbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    color: #ffffff;
    font-size: 1.05rem;
    font-weight: 700;
    font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
    letter-spacing: -0.01em;
  }

  .navbar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: auto;
    min-height: 70px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .navbar-logo {
    grid-column: 2;
    justify-self: center;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
    flex-direction: column;
  }

  .logo-text {
    color: #ffffff;
    font-size: 1.2rem;
    font-weight: 700;
    font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .navbar-subtitle {
    color: #94a3b8;
    font-size: 0.7rem;
    font-weight: 500;
    line-height: 1;
  }

  .navbar-links {
    grid-column: 3;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 2rem;
    justify-content: flex-end;
  }

  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-section-label {
    color: #64748b;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-item-wrapper {
    display: flex;
    gap: 0.25rem;
  }

  .nav-links-row {
    display: flex;
    gap: 0.25rem;
  }

  .nav-link {
    color: #94a3b8;
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.825rem;
    font-weight: 500;
    transition: all 0.15s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid transparent;
  }

  .nav-link:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
  }

  .nav-link.active {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.15);
    border-color: rgba(245, 158, 11, 0.3);
  }

  .nav-link-primary {
    font-weight: 600;
    padding: 0.6rem 0.9rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .nav-highlight {
    background: rgba(59, 130, 246, 0.1);
    color: #60a5fa;
  }

  .nav-highlight:hover {
    background: rgba(59, 130, 246, 0.2);
    color: #93c5fd;
  }

  .nav-enterprise {
    background: rgba(16, 185, 129, 0.1);
    color: #34d399;
    position: relative;
  }

  .nav-enterprise:hover {
    background: rgba(16, 185, 129, 0.2);
    color: #6ee7b7;
  }

  .nav-enterprise::after {
    content: '✓';
    position: absolute;
    top: -4px;
    right: -4px;
    background: #10b981;
    color: white;
    border-radius: 50%;
    width: 14px;
    height: 14px;
    font-size: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .nav-badge {
    font-size: 0.65rem;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.1);
    color: #e2e8f0;
    padding: 0.15rem 0.4rem;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    color: #94a3b8;
    font-size: 0.825rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .nav-dropdown-trigger:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .dropdown-arrow {
    font-size: 0.6rem;
    transition: transform 0.15s ease;
  }

  .nav-dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0.5rem;
    background: #0f172a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 0.5rem;
    min-width: 220px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.15s ease;
    z-index: 1000;
  }

  .nav-dropdown:hover .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 4px;
    color: #cbd5e1;
    text-decoration: none;
    font-size: 0.825rem;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .nav-dropdown-item:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  .enterprise-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.825rem;
    font-weight: 600;
    transition: all 0.15s ease;
    border: 1px solid rgba(16, 185, 129, 0.3);
    white-space: nowrap;
  }

  .enterprise-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
    background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  }

  .enterprise-icon {
    font-size: 1rem;
  }

  @media (max-width: 1200px) {
    .navbar-links {
      gap: 1rem;
    }
    
    .nav-section-label {
      display: none;
    }
  }

  @media (max-width: 992px) {
    .navbar-links {
      gap: 0.75rem;
    }
    
    .nav-item-wrapper {
      flex-wrap: wrap;
      max-width: 200px;
    }
  }

  @media (max-width: 768px) {
    .navbar-inner {
      height: auto;
      padding: 0.75rem 1rem;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }

    .navbar-logo {
      grid-column: unset;
      justify-self: unset;
      align-items: center;
    }

    .navbar-links {
      grid-column: unset;
      justify-self: unset;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }

    .nav-section {
      width: 100%;
    }

    .nav-section-label {
      display: block;
      text-align: center;
    }

    .nav-item-wrapper {
      max-width: none;
      justify-content: center;
    }

    .nav-link {
      flex: 1;
      justify-content: center;
    }

    .enterprise-cta {
      width: 100%;
      justify-content: center;
    }

    .nav-dropdown-menu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      margin-top: 0.5rem;
      width: 100%;
    }
  }
</style>

---
/**
 * AskAI.astro — "Ask an AI" second-opinion section.
 *
 * A row of buttons that open the visitor's favorite AI chatbot with a
 * pre-filled, context-rich prompt about My MCP Shelf. Each button is a
 * plain hyperlink (no JS needed for the click); the prompt is URL-encoded
 * server-side in this frontmatter.
 *
 * Platforms: ChatGPT, Claude, Perplexity, Copilot (Grok intentionally skipped).
 * Theme: matches the site's "Warm Earth" palette + html.dark-mode toggle.
 * Tracking: Plausible "Ask AI Click" events.
 */
const config = {
  productName: 'My MCP Shelf',
  url: 'https://www.mymcpshelf.com/',
  useCase: 'find and choose reliable Model Context Protocol (MCP) servers for my AI tools',
  alternatives: ['Smithery', 'Glama', 'searching GitHub directly'],
};

const prompt = `How would ${config.productName} at ${config.url} help me ${config.useCase}, and what makes it different from ${config.alternatives.join(', ')}? Be honest about who it's best for and where it falls short.`;

const encoded = encodeURIComponent(prompt);

// Brand accent color is applied on hover (and as the icon tint).
const platforms = [
  {
    key: 'chatgpt',
    label: 'Ask ChatGPT',
    href: `https://chatgpt.com/?q=${encoded}`,
    accent: '#10a37f',
  },
  {
    key: 'claude',
    label: 'Ask Claude',
    href: `https://claude.ai/new?q=${encoded}`,
    accent: '#d97757',
  },
  {
    key: 'perplexity',
    label: 'Ask Perplexity',
    href: `https://www.perplexity.ai/?q=${encoded}`,
    accent: '#20b8c6',
  },
  {
    key: 'copilot',
    label: 'Ask Copilot',
    href: `https://copilot.microsoft.com/?q=${encoded}`,
    accent: '#2563eb',
  },
];
---

<section class="ask-ai-section" id="ask-ai" aria-label="Ask an AI about My MCP Shelf">
  <div class="ask-ai-container">
    <span class="ask-ai-eyebrow" aria-hidden="true">Second opinion</span>
    <h2 class="ask-ai-heading">Still deciding? Ask an AI.</h2>
    <p class="ask-ai-subheading">
      Get an honest, third-party take on whether My MCP Shelf fits your workflow.
      We've pre-written the question — just pick the AI you already trust.
    </p>

    <div class="ask-ai-buttons">
      {platforms.map((p) => (
        <a
          class={`ask-ai-button ask-ai-${p.key}`}
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          data-ai-platform={p.key}
          aria-label={`Ask ${p.label.replace('Ask ', '')} about My MCP Shelf`}
        >
          <span class="ask-ai-icon" aria-hidden="true">
            {p.key === 'chatgpt' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            )}
            {p.key === 'claude' && (
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.5c.32 3.06 1.94 4.68 5 5-3.06.32-4.68 1.94-5 5-.32-3.06-1.94-4.68-5-5 3.06-.32 4.68-1.94 5-5z"/><path d="M18.5 13.5c.2 1.7 1.05 2.55 2.75 2.75-1.7.2-2.55 1.05-2.75 2.75-.2-1.7-1.05-2.55-2.75-2.75 1.7-.2 2.55-1.05 2.75-2.75z"/></svg>
            )}
            {p.key === 'perplexity' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            )}
            {p.key === 'copilot' && (
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.9 6.1L20 10l-6.1 1.9L12 18l-1.9-6.1L4 10l6.1-1.9L12 2z"/></svg>
            )}
          </span>
          <span class="ask-ai-label">{p.label}</span>
        </a>
      ))}
    </div>

    <p class="ask-ai-note">Opens in a new tab · Your conversation stays private to you and the AI.</p>

    <div class="ask-ai-comparisons">
      <span class="comparisons-label">Or read our honest comparisons:</span>
      <div class="comparisons-links">
        <a href="/vs-glama">vs Glama</a>
        <a href="/vs-smithery">vs Smithery</a>
        <a href="/vs-mcp.so">vs mcp.so</a>
        <a href="/vs-skills.sh">vs skills.sh</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Light mode (Warm Earth) — local vars so the section is robust whether or
     not the global design tokens flip. */
  .ask-ai-section {
    --aa-bg: hsl(var(--muted));
    --aa-surface: hsl(var(--card));
    --aa-surface-hover: hsl(var(--card));
    --aa-heading: hsl(var(--foreground));
    --aa-body: hsl(var(--muted-foreground));
    --aa-border: hsl(var(--border));

    background: var(--aa-bg);
    padding: 4rem 1rem;
    border-top: 1px solid var(--aa-border);
  }

  .ask-ai-container {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .ask-ai-eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    margin-bottom: 0.6rem;
  }

  .ask-ai-heading {
    font-size: 2rem;
    font-weight: 700;
    color: var(--aa-heading);
    margin-bottom: 0.6rem;
    line-height: 1.2;
  }

  .ask-ai-subheading {
    font-size: 1.05rem;
    color: var(--aa-body);
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto 2rem;
  }

  .ask-ai-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .ask-ai-button {
    --aa-accent: hsl(var(--primary));

    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.25rem;
    border-radius: 0.625rem;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    background: var(--aa-surface);
    color: var(--aa-heading);
    border: 1px solid var(--aa-border);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, color 0.18s ease;
  }

  .ask-ai-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    border-color: var(--aa-accent);
    color: var(--aa-accent);
  }

  .ask-ai-button:focus-visible {
    outline: 2px solid var(--aa-accent);
    outline-offset: 2px;
  }

  /* Platform brand accents */
  .ask-ai-chatgpt { --aa-accent: #10a37f; }
  .ask-ai-claude { --aa-accent: #d97757; }
  .ask-ai-perplexity { --aa-accent: #20b8c6; }
  .ask-ai-copilot { --aa-accent: #2563eb; }

  .ask-ai-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: color 0.18s ease;
  }

  .ask-ai-icon :global(svg),
  .ask-ai-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ask-ai-label {
    line-height: 1;
  }

  .ask-ai-note {
    margin-top: 1.5rem;
    font-size: 0.82rem;
    color: var(--aa-body);
    opacity: 0.85;
  }

  .ask-ai-comparisons {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--aa-border);
  }

  .comparisons-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--aa-body);
    margin-bottom: 0.6rem;
  }

  .comparisons-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .comparisons-links a {
    padding: 0.35rem 0.75rem;
    background: var(--aa-surface);
    border: 1px solid var(--aa-border);
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--aa-body);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .comparisons-links a:hover {
    border-color: hsl(var(--primary));
    color: hsl(var(--primary));
    transform: translateY(-1px);
  }

  /* Dark mode (html.dark-mode) — Warm Earth dark palette values */
  :global(html.dark-mode) .ask-ai-section {
    --aa-bg: hsl(270 25% 12%);
    --aa-surface: hsl(270 25% 16%);
    --aa-surface-hover: hsl(270 25% 20%);
    --aa-heading: hsl(270 5% 95%);
    --aa-body: hsl(270 5% 65%);
    --aa-border: hsl(270 20% 24%);
  }

  :global(html.dark-mode) .ask-ai-button {
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }

  :global(html.dark-mode) .ask-ai-button:hover {
    background: var(--aa-surface-hover);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
  }

  /* Mobile */
  @media (max-width: 560px) {
    .ask-ai-heading {
      font-size: 1.6rem;
    }
    .ask-ai-subheading {
      font-size: 0.98rem;
    }
    .ask-ai-buttons {
      flex-direction: column;
      align-items: stretch;
    }
    .ask-ai-button {
      justify-content: center;
      padding: 0.85rem 1rem;
    }
  }
</style>

<script>
  // Plausible click tracking — purely a top-of-funnel signal.
  document.addEventListener('click', function (event) {
    const target = event.target;
    const btn = target && typeof target.closest === 'function' ? target.closest('[data-ai-platform]') : null;
    if (!btn) return;
    const platform = btn.getAttribute('data-ai-platform');
    if (typeof plausible !== 'undefined' && platform) {
      plausible('Ask AI Click', { props: { platform } });
    }
  });
</script>

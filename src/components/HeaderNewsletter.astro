---
// Compact Header Newsletter Signup with Email Input
---

<div class="header-newsletter">
    <span class="newsletter-label">📬 Get weekly AI & MCP updates:</span>
    <form class="newsletter-form" id="headerNewsletterForm">
        <input
            type="email"
            class="email-input"
            placeholder="Enter your email"
            required
            id="headerEmailInput"
        />
        <button type="submit" class="subscribe-btn">Subscribe</button>
    </form>
</div>

<div class="newsletter-success" id="newsletterSuccess" style="display: none;">
    <span class="success-message">✓ Thanks for subscribing!</span>
</div>

<style>
    .header-newsletter {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 0.75rem 1.5rem;
        background: hsl(var(--card));
        border-radius: 50px;
        border: 1px solid hsl(var(--border));
    }

    .newsletter-label {
        color: hsl(var(--foreground));
        font-size: 0.9rem;
        font-weight: 500;
        white-space: nowrap;
    }

    .newsletter-form {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .email-input {
        padding: 0.5rem 1rem;
        border: 2px solid hsl(var(--border));
        border-radius: 25px;
        font-size: 0.9rem;
        background: hsl(var(--background));
        color: hsl(var(--foreground));
        min-width: 180px;
        outline: none;
        transition: border-color 0.2s ease;
    }

    .email-input::placeholder {
        color: hsl(var(--muted-foreground));
    }

    .email-input:focus {
        border-color: hsl(var(--primary));
    }

    .subscribe-btn {
        padding: 0.5rem 1.25rem;
        background: hsl(var(--primary));
        color: white;
        border: none;
        border-radius: 25px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }

    .subscribe-btn:hover {
        background: hsl(var(--primary) / 0.9);
        transform: translateY(-1px);
    }

    .newsletter-success {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1.5rem;
        background: hsl(142 76% 36%);
        border-radius: 50px;
        margin-top: 0.5rem;
    }

    .success-message {
        color: white;
        font-size: 0.9rem;
        font-weight: 500;
    }

    @media (max-width: 768px) {
        .header-newsletter {
            flex-direction: column;
            align-items: stretch;
            padding: 1rem;
            border-radius: 15px;
            text-align: center;
        }

        .newsletter-form {
            flex-direction: column;
            width: 100%;
        }

        .email-input {
            width: 100%;
            min-width: unset;
        }

        .subscribe-btn {
            width: 100%;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('headerNewsletterForm');
        const success = document.getElementById('newsletterSuccess');
        const newsletter = document.querySelector('.header-newsletter');

        if (form) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const email = document.getElementById('headerEmailInput').value;

                // Store email locally (you can replace this with actual API call)
                console.log('Newsletter signup:', email);

                // Show success message
                if (newsletter) newsletter.style.display = 'none';
                if (success) success.style.display = 'flex';

                // Reset form
                form.reset();

                // Hide success after 5 seconds and show form again
                setTimeout(() => {
                    if (success) success.style.display = 'none';
                    if (newsletter) newsletter.style.display = 'flex';
                }, 5000);
            });
        }
    });
</script>

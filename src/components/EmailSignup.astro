---
// Email Signup Component - Ghost Signup Form Embed
---

<div class="email-signup">
    <div class="signup-container">
        <script
            src="https://cdn.jsdelivr.net/ghost/signup-form@~0.2/umd/signup-form.min.js"
            data-background-color="#08090c"
            data-text-color="#FFFFFF"
            data-button-color="#FF1A75"
            data-button-text-color="#FFFFFF"
            data-title="BrainScriblr"
            data-description="AI and MCP News"
            data-icon="https://ghost-production-5d84.up.railway.app/content/images/size/w192h192/size/w256h256/2026/02/brainscriblr-logo-with-just-an-outline-o_zsa1GE-VQdmUY3kF3mHI5A_HowW9EU2T9etjgePuCs7ow_hd.png"
            data-site="https://ghost-production-5d84.up.railway.app/"
            data-locale="en"
            async
        ></script>
    </div>
    
    <!-- Custom MCP System CTA -->
    <div class="custom-mcp-cta">
        <div class="cta-content">
            <h3 class="cta-heading">Need a Custom MCP System?</h3>
            <p class="cta-text">We configure and integrate MCP systems — from tool selection to production deployment.</p>
            <a href="https://www.salishseaconsulting.com/contact/" class="cta-button btn btn-primary" target="_blank" rel="noopener noreferrer">
                Get Started →
            </a>
        </div>
    </div>
</div>

<style>
    .email-signup {
        background: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--secondary)) 100%);
        padding: 3rem 2rem;
        margin: 4rem 0;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .signup-container {
        max-width: 600px;
        margin: 0 auto;
        min-height: 360px;
    }

    .custom-mcp-cta {
        max-width: 600px;
        margin: 2rem auto 0;
        padding: 1.5rem;
        background: rgba(0, 0, 0, 0.2);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .cta-content {
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
    }

    .cta-heading {
        font-size: 1.25rem;
        font-weight: 700;
        color: #ffffff;
        margin: 0;
        font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .cta-text {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
        line-height: 1.5;
        max-width: 400px;
    }

    .cta-button {
        padding: 0.75rem 1.5rem;
        background: #ffffff;
        color: #333;
        font-weight: 600;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
        background: #f8fafc;
    }

    .btn {
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: #ffffff;
        color: #333;
    }

    @media (max-width: 600px) {
        .email-signup {
            padding: 2rem 1.5rem;
            margin: 2rem 0;
        }
        
        .custom-mcp-cta {
            margin: 1.5rem auto 0;
            padding: 1.25rem;
        }
        
        .cta-heading {
            font-size: 1.1rem;
        }
        
        .cta-text {
            font-size: 0.9rem;
        }
    }
</style>

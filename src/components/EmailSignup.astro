---
// Email Signup Component - Ghost Signup Form Embed
---

<div class="email-signup">
    <div class="signup-container">
        <script
            src="https://cdn.jsdelivr.net/ghost/signup-form@~0.2/umd/signup-form.min.js"
            data-background-color="#08090c"
            data-text-color="#FFFFFF"
            data-button-color="#FF1A75"
            data-button-text-color="#FFFFFF"
            data-title="BrainScriblr"
            data-description="AI and MCP News"
            data-icon="https://ghost-production-5d84.up.railway.app/content/images/size/w192h192/size/w256h256/2026/02/brainscriblr-logo-with-just-an-outline-o_zsa1GE-VQdmUY3kF3mHI5A_HowW9EU2T9etjgePuCs7ow_hd.png"
            data-site="https://ghost-production-5d84.up.railway.app/"
            data-locale="en"
            async
        ></script>
    </div>
</div>

<style>
    .email-signup {
        background: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--secondary)) 100%);
        padding: 3rem 2rem;
        margin: 4rem 0;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .signup-container {
        max-width: 600px;
        margin: 0 auto;
        min-height: 360px;
    }

    @media (max-width: 600px) {
        .email-signup {
            padding: 2rem 1.5rem;
            margin: 2rem 0;
        }
    }
</style>
